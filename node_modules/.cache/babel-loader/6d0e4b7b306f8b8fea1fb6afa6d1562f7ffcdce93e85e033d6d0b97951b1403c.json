'password'\"\n              class=\"w-full px-4 py-3 border rounded-md focus:ring-2 focus:ring-blue-500 focus:outline-none pr-10\"\n              required\n            />\n            <button\n              type=\"button\"\n              @click=\"togglePassword\"\n              class=\"absolute inset-y-0 right-3 flex items-center text-gray-500\"\n            >\n              <i :class=\"showPassword ? 'fas fa-eye-slash' : 'fas fa-eye'\"></i>\n            </button>\n          </div>\n          <div class=\"flex justify-between items-center mb-4\">\n            <label class=\"flex items-center\">\n              <input\n                type=\"checkbox\"\n                class=\"form-checkbox text-blue-600 h-4 w-4\"\n              />\n              <span class=\"ml-2 text-gray-700\">Remember me</span>\n            </label>\n            <a href=\"#\" class=\"text-blue-500 text-sm hover:underline\"\n              >Forgot password?</a\n            >\n          </div>\n          <button\n            type=\"submit\"\n            class=\"w-full bg-blue-500 text-white py-3 rounded-md hover:bg-blue-600 transition duration-300\"\n            :disabled=\"loading\"\n          >\n            {{ loading ? \"Logging in...\" : \"Log in\" }}\n          </button>\n          <div v-if=\"error\" class=\"text-red-500 text-sm mt-4\">{{ error }}</div>\n        </form>\n        <p class=\"mt-6 text-sm text-center\">\n          Don't have an account?\n          <a href=\"/register\" class=\"text-blue-500 hover:underline\">Sign Up</a>\n        </p>\n      </div>\n\n      <!-- Right: Website Performance Live Chart -->\n      <div\n        class=\"hidden md:flex w-1/2 bg-blue-50 p-8 flex-col justify-center items-center text-center\"\n      >\n        <h3 class=\"text-lg font-semibold mb-4\">Live Website Performance</h3>\n        <canvas id=\"performanceChart\" width=\"300\" height=\"200\"></canvas>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { useRouter } from \"vue-router\";\nimport { login } from \"../services/api.js\";\nimport Chart from \"chart.js/auto\";\n\nexport default {\n  name: \"LoginPage\",\n  data() {\n    return {\n      email: \"\",\n      password: \"\",\n      showPassword: false,\n      loading: false,\n      error: null,\n    };\n  },\n  setup() {\n    const router = useRouter();\n    return { router };\n  },\n  mounted() {\n    this.renderChart();\n  },\n  methods: {\n    togglePassword() {\n      this.showPassword = !this.showPassword;\n    },\n    async handleLogin() {\n      if (!this.email || !this.password) {\n        alert(\"Email and Password are required.\");\n        return;\n      }\n      this.loading = true;\n      this.error = null;\n      try {\n        const response = await login({\n          email: this.email,\n          password: this.password,\n        });\n        const user = response.data.user || response.data.data?.data;\n        if (!user) {\n          throw new Error(\"User data missing in response\");\n        }\n        sessionStorage.setItem(\"token\", response.data.token);\n        sessionStorage.setItem(\"user_id\", user.id);\n        this.router.push(\"/dashboard\");\n      } catch (error) {\n        this.error = error.response?.data?.message || \"An error occurred.\";\n      } finally {\n        this.loading = false;\n      }\n    },\n    renderChart() {\n      const ctx = document.getElementById(\"performanceChart\").getContext(\"2d\");\n      new Chart(ctx, {\n        type: \"line\",\n        data: {\n          labels: [\"1s ago\", \"2s ago\", \"3s ago\", \"4s ago\", \"5s ago\"],\n          datasets: [\n            {\n              label: \"Response Time (ms)\",\n              data: [120, 110, 140, 130, 100],\n              borderColor: \"blue\",\n              borderWidth: 2,\n              fill: false,\n            },\n          ],\n        },\n        options: {\n          responsive: true,\n          scales: {\n            y: {\n              beginAtZero: true,\n            },\n          },\n        },\n      });\n    },\n  },\n};\n</script>\n\n<style scoped>\n.bg-gray-100 {\n  background-color: #f4f4f9;\n}\n</style>\n"],"mappings":";;;;;AA8EA,SAASA,SAAQ,QAAS,YAAY;AACtC,SAASC,KAAI,QAAS,oBAAoB;AAC1C,OAAOC,KAAI,MAAO,eAAe;AAEjC,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,YAAY,EAAE,KAAK;MACnBC,OAAO,EAAE,KAAK;MACdC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,KAAK,WAALA,KAAKA,CAAA,EAAG;IACN,IAAMC,MAAK,GAAIX,SAAS,CAAC,CAAC;IAC1B,OAAO;MAAEW,MAAK,EAALA;IAAO,CAAC;EACnB,CAAC;EACDC,OAAO,WAAPA,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,WAAW,CAAC,CAAC;EACpB,CAAC;EACDC,OAAO,EAAE;IACPC,cAAc,WAAdA,cAAcA,CAAA,EAAG;MACf,IAAI,CAACR,YAAW,GAAI,CAAC,IAAI,CAACA,YAAY;IACxC,CAAC;IACKS,WAAW,WAAXA,WAAWA,CAAA,EAAG;MAAA,IAAAC,KAAA;MAAA,OAAAC,iBAAA,cAAAC,mBAAA,GAAAC,IAAA,UAAAC,QAAA;QAAA,IAAAC,mBAAA,EAAAC,QAAA,EAAAC,IAAA,EAAAC,eAAA;QAAA,OAAAN,mBAAA,GAAAO,IAAA,UAAAC,SAAAC,QAAA;UAAA,kBAAAA,QAAA,CAAAC,IAAA,GAAAD,QAAA,CAAAE,IAAA;YAAA;cAAA,MACd,CAACb,KAAI,CAACZ,KAAI,IAAK,CAACY,KAAI,CAACX,QAAQ;gBAAAsB,QAAA,CAAAE,IAAA;gBAAA;cAAA;cAC/BC,KAAK,CAAC,kCAAkC,CAAC;cAAA,OAAAH,QAAA,CAAAI,MAAA;YAAA;cAG3Cf,KAAI,CAACT,OAAM,GAAI,IAAI;cACnBS,KAAI,CAACR,KAAI,GAAI,IAAI;cAAAmB,QAAA,CAAAC,IAAA;cAAAD,QAAA,CAAAE,IAAA;cAAA,OAEQ7B,KAAK,CAAC;gBAC3BI,KAAK,EAAEY,KAAI,CAACZ,KAAK;gBACjBC,QAAQ,EAAEW,KAAI,CAACX;cACjB,CAAC,CAAC;YAAA;cAHIiB,QAAO,GAAAK,QAAA,CAAAK,IAAA;cAIPT,IAAG,GAAID,QAAQ,CAACnB,IAAI,CAACoB,IAAG,MAAAF,mBAAA,GAAKC,QAAQ,CAACnB,IAAI,CAACA,IAAI,cAAAkB,mBAAA,uBAAlBA,mBAAA,CAAoBlB,IAAI;cAAA,IACtDoB,IAAI;gBAAAI,QAAA,CAAAE,IAAA;gBAAA;cAAA;cAAA,MACD,IAAII,KAAK,CAAC,+BAA+B,CAAC;YAAA;cAElDC,cAAc,CAACC,OAAO,CAAC,OAAO,EAAEb,QAAQ,CAACnB,IAAI,CAACiC,KAAK,CAAC;cACpDF,cAAc,CAACC,OAAO,CAAC,SAAS,EAAEZ,IAAI,CAACc,EAAE,CAAC;cAC1CrB,KAAI,CAACN,MAAM,CAAC4B,IAAI,CAAC,YAAY,CAAC;cAAAX,QAAA,CAAAE,IAAA;cAAA;YAAA;cAAAF,QAAA,CAAAC,IAAA;cAAAD,QAAA,CAAAY,EAAA,GAAAZ,QAAA;cAE9BX,KAAI,CAACR,KAAI,GAAI,EAAAgB,eAAA,GAAAG,QAAA,CAAAY,EAAA,CAAMjB,QAAQ,cAAAE,eAAA,gBAAAA,eAAA,