{"ast":null,"code":"import \"core-js/modules/es.array.filter.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nexport default {\n  props: {\n    results: {\n      type: Object,\n      \"default\": function _default() {\n        return {\n          pages: []\n        };\n      }\n    }\n  },\n  data: function data() {\n    return {\n      selectedPage: null\n    };\n  },\n  computed: {\n    filteredResults: function filteredResults() {\n      return this.results.pages;\n    },\n    errorCount: function errorCount() {\n      return this.results.pages.filter(function (p) {\n        return p.is_description_missing || !p.is_title_ideal && !p.is_title_too_short || p.hasHttps === \"No\";\n      }).length;\n    },\n    warningCount: function warningCount() {\n      return this.results.pages.filter(function (p) {\n        return p.is_title_too_short || p.is_description_duplicate;\n      }).length;\n    },\n    validCount: function validCount() {\n      return this.results.pages.length - this.errorCount - this.warningCount;\n    },\n    httpsCount: function httpsCount() {\n      return this.results.pages.filter(function (p) {\n        return p.hasHttps === \"Yes\";\n      }).length;\n    },\n    dupCount: function dupCount() {\n      return this.results.pages.filter(function (p) {\n        return p.is_title_duplicate;\n      }).length;\n    }\n  },\n  methods: {\n    getTitleStatus: function getTitleStatus(page) {\n      if (page.is_title_ideal) return \"Ideal\";\n      if (page.is_title_too_short) return \"Too Short\";\n      return \"Too Long\";\n    },\n    getMetaStatus: function getMetaStatus(page) {\n      if (page.is_description_missing) return \"Missing\";\n      if (page.is_description_duplicate) return \"Duplicate\";\n      return \"Valid\";\n    },\n    selectRow: function selectRow(page) {\n      this.selectedPage = page;\n    }\n  }\n};","map":{"version":3,"names":["props","results","type","Object","default","pages","data","selectedPage","computed","filteredResults","errorCount","filter","p","is_description_missing","is_title_ideal","is_title_too_short","hasHttps","length","warningCount","is_description_duplicate","validCount","httpsCount","dupCount","is_title_duplicate","methods","getTitleStatus","page","getMetaStatus","selectRow"],"sources":["C:\\Users\\RYZEN 5 5500\\Documents\\GitHub\\webdiagnostic-fe-m1\\src\\components\\ValidationResults.vue"],"sourcesContent":["<template>\n  <div class=\"results-container text-sm\">\n    <div class=\"scanned-pages\">\n      <h2 class=\"text-lg font-semibold mb-4\">Scanned Pages</h2>\n\n      <!-- Main Layout -->\n      <div class=\"grid grid-cols-12 gap-4\">\n        <!-- Main Table Panel -->\n        <div\n          class=\"col-span-9 overflow-auto max-h-[600px] border rounded shadow\"\n        >\n          <table class=\"min-w-full text-xs\">\n            <thead class=\"bg-gray-100 sticky top-0 z-10\">\n              <tr>\n                <th class=\"p-2\">#</th>\n                <th class=\"p-2\">URL</th>\n                <th class=\"p-2\">Title</th>\n                <th class=\"p-2\">Title Length</th>\n                <th class=\"p-2\">Title Status</th>\n                <th class=\"p-2\">Meta Description</th>\n                <th class=\"p-2\">Meta Length</th>\n                <th class=\"p-2\">Meta Status</th>\n                <th class=\"p-2\">HTTPS</th>\n                <th class=\"p-2\">Duplicate Title</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr\n                v-for=\"(page, index) in filteredResults\"\n                :key=\"index\"\n                @click=\"selectRow(page)\"\n                class=\"border-b hover:bg-gray-100 cursor-pointer\"\n              >\n                <td class=\"p-2 text-center\">{{ index + 1 }}</td>\n                <td class=\"p-2 break-words max-w-[200px]\">\n                  <a\n                    :href=\"page.url\"\n                    target=\"_blank\"\n                    class=\"text-blue-600 underline\"\n                    >{{ page.url }}</a\n                  >\n                </td>\n                <td class=\"p-2\">{{ page.title }}</td>\n                <td class=\"p-2 text-center\">{{ page.title_length }}</td>\n                <td class=\"p-2 text-center\">{{ getTitleStatus(page) }}</td>\n                <td class=\"p-2\">{{ page.description }}</td>\n                <td class=\"p-2 text-center\">\n                  {{ page.description_length || \"—\" }}\n                </td>\n                <td class=\"p-2 text-center\">{{ getMetaStatus(page) }}</td>\n                <td class=\"p-2 text-center\">\n                  <span\n                    :class=\"\n                      page.hasHttps === 'Yes'\n                        ? 'text-green-600'\n                        : 'text-red-600'\n                    \"\n                    >{{ page.hasHttps }}</span\n                  >\n                </td>\n                <td class=\"p-2 text-center\">\n                  <span\n                    :class=\"\n                      page.is_title_duplicate\n                        ? 'text-red-600'\n                        : 'text-green-600'\n                    \"\n                  >\n                    {{ page.is_title_duplicate ? \"Yes\" : \"No\" }}\n                  </span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n\n        <!-- Summary Sidebar -->\n        <div class=\"col-span-3 bg-white border rounded p-4 shadow-sm\">\n          <h3 class=\"font-semibold text-gray-700 mb-2\">Summary</h3>\n          <ul class=\"text-xs space-y-1\">\n            <li>Total Pages: {{ results.pages.length }}</li>\n            <li>Errors: {{ errorCount }}</li>\n            <li>Warnings: {{ warningCount }}</li>\n            <li>Valid: {{ validCount }}</li>\n            <li>HTTPS: {{ httpsCount }}</li>\n            <li>Duplicate Titles: {{ dupCount }}</li>\n          </ul>\n        </div>\n      </div>\n\n      <!-- Detail Panel -->\n      <div v-if=\"selectedPage\" class=\"mt-4 border rounded p-4 bg-gray-50\">\n        <h3 class=\"text-sm font-semibold mb-2\">\n          Details for: <span class=\"text-blue-600\">{{ selectedPage.url }}</span>\n        </h3>\n        <ul class=\"text-xs space-y-1\">\n          <li><strong>Title:</strong> {{ selectedPage.title }}</li>\n          <li>\n            <strong>Title Length:</strong> {{ selectedPage.title_length }} ({{\n              getTitleStatus(selectedPage)\n            }})\n          </li>\n          <li>\n            <strong>Meta Description:</strong> {{ selectedPage.description }}\n          </li>\n          <li>\n            <strong>Meta Length:</strong>\n            {{ selectedPage.description_length }} ({{\n              getMetaStatus(selectedPage)\n            }})\n          </li>\n          <li><strong>HTTPS:</strong> {{ selectedPage.hasHttps }}</li>\n          <li><strong>Phone:</strong> {{ selectedPage.phone }}</li>\n          <li><strong>Email:</strong> {{ selectedPage.email }}</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  props: {\n    results: {\n      type: Object,\n      default: () => ({ pages: [] }),\n    },\n  },\n  data() {\n    return {\n      selectedPage: null,\n    };\n  },\n  computed: {\n    filteredResults() {\n      return this.results.pages;\n    },\n    errorCount() {\n      return this.results.pages.filter(\n        (p) =>\n          p.is_description_missing ||\n          (!p.is_title_ideal && !p.is_title_too_short) ||\n          p.hasHttps === \"No\"\n      ).length;\n    },\n    warningCount() {\n      return this.results.pages.filter(\n        (p) => p.is_title_too_short || p.is_description_duplicate\n      ).length;\n    },\n    validCount() {\n      return this.results.pages.length - this.errorCount - this.warningCount;\n    },\n    httpsCount() {\n      return this.results.pages.filter((p) => p.hasHttps === \"Yes\").length;\n    },\n    dupCount() {\n      return this.results.pages.filter((p) => p.is_title_duplicate).length;\n    },\n  },\n  methods: {\n    getTitleStatus(page) {\n      if (page.is_title_ideal) return \"Ideal\";\n      if (page.is_title_too_short) return \"Too Short\";\n      return \"Too Long\";\n    },\n    getMetaStatus(page) {\n      if (page.is_description_missing) return \"Missing\";\n      if (page.is_description_duplicate) return \"Duplicate\";\n      return \"Valid\";\n    },\n    selectRow(page) {\n      this.selectedPage = page;\n    },\n  },\n};\n</script>\n\n<style scoped>\nth,\ntd {\n  white-space: nowrap;\n}\n</style>\n"],"mappings":";;;;AAyHA,eAAe;EACbA,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZ,WAAS,SAATC,QAAOA,CAAA;QAAA,OAAS;UAAEC,KAAK,EAAE;QAAG,CAAC;MAAA;IAC/B;EACF,CAAC;EACDC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,eAAe,WAAfA,eAAeA,CAAA,EAAG;MAChB,OAAO,IAAI,CAACR,OAAO,CAACI,KAAK;IAC3B,CAAC;IACDK,UAAU,WAAVA,UAAUA,CAAA,EAAG;MACX,OAAO,IAAI,CAACT,OAAO,CAACI,KAAK,CAACM,MAAM,CAC9B,UAACC,CAAC;QAAA,OACAA,CAAC,CAACC,sBAAqB,IACtB,CAACD,CAAC,CAACE,cAAa,IAAK,CAACF,CAAC,CAACG,kBAAkB,IAC3CH,CAAC,CAACI,QAAO,KAAM,IAAG;MAAA,CACtB,CAAC,CAACC,MAAM;IACV,CAAC;IACDC,YAAY,WAAZA,YAAYA,CAAA,EAAG;MACb,OAAO,IAAI,CAACjB,OAAO,CAACI,KAAK,CAACM,MAAM,CAC9B,UAACC,CAAC;QAAA,OAAKA,CAAC,CAACG,kBAAiB,IAAKH,CAAC,CAACO,wBAAuB;MAAA,CAC1D,CAAC,CAACF,MAAM;IACV,CAAC;IACDG,UAAU,WAAVA,UAAUA,CAAA,EAAG;MACX,OAAO,IAAI,CAACnB,OAAO,CAACI,KAAK,CAACY,MAAK,GAAI,IAAI,CAACP,UAAS,GAAI,IAAI,CAACQ,YAAY;IACxE,CAAC;IACDG,UAAU,WAAVA,UAAUA,CAAA,EAAG;MACX,OAAO,IAAI,CAACpB,OAAO,CAACI,KAAK,CAACM,MAAM,CAAC,UAACC,CAAC;QAAA,OAAKA,CAAC,CAACI,QAAO,KAAM,KAAK;MAAA,EAAC,CAACC,MAAM;IACtE,CAAC;IACDK,QAAQ,WAARA,QAAQA,CAAA,EAAG;MACT,OAAO,IAAI,CAACrB,OAAO,CAACI,KAAK,CAACM,MAAM,CAAC,UAACC,CAAC;QAAA,OAAKA,CAAC,CAACW,kBAAkB;MAAA,EAAC,CAACN,MAAM;IACtE;EACF