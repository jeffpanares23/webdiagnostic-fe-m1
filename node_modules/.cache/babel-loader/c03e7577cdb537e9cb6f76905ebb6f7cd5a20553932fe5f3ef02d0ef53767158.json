{"ast":null,"code":"import \"core-js/modules/es.symbol.js\";\nimport \"core-js/modules/es.symbol.description.js\";\nimport \"core-js/modules/es.array.filter.js\";\nimport \"core-js/modules/es.array.for-each.js\";\nimport \"core-js/modules/es.array.includes.js\";\nimport \"core-js/modules/es.array.slice.js\";\nimport \"core-js/modules/es.array.sort.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport \"core-js/modules/es.string.includes.js\";\nimport \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport \"core-js/modules/esnext.iterator.for-each.js\";\nimport \"core-js/modules/web.dom-collections.for-each.js\";\nexport default {\n  props: {\n    results: {\n      type: Object,\n      \"default\": function _default() {\n        return {\n          pages: []\n        };\n      }\n    }\n  },\n  data: function data() {\n    return {\n      searchQuery: \"\",\n      filterType: \"\",\n      expandedIndex: null,\n      page: 1,\n      itemsPerPage: 10,\n      sortKey: \"url\",\n      sortOrder: \"asc\"\n    };\n  },\n  computed: {\n    filteredResults: function filteredResults() {\n      var _this = this;\n      var filtered = this.results.pages;\n\n      // Search Query\n      if (this.searchQuery) {\n        filtered = filtered.filter(function (page) {\n          return page.url.includes(_this.searchQuery) || page.title.includes(_this.searchQuery);\n        });\n      }\n\n      // Filtering\n      if (this.filterType === \"missingDescription\") {\n        filtered = filtered.filter(function (page) {\n          return !page.description;\n        });\n      } else if (this.filterType === \"noHttps\") {\n        filtered = filtered.filter(function (page) {\n          return page.hasHttps === \"No\";\n        });\n      } else if (this.filterType === \"duplicateTitle\") {\n        var titleCounts = {};\n        filtered.forEach(function (page) {\n          titleCounts[page.title] = (titleCounts[page.title] || 0) + 1;\n        });\n        filtered = filtered.filter(function (page) {\n          return titleCounts[page.title] > 1;\n        });\n      }\n\n      // Sorting\n      filtered.sort(function (a, b) {\n        var modifier = _this.sortOrder === \"asc\" ? 1 : -1;\n        if (a[_this.sortKey] < b[_this.sortKey]) return -1 * modifier;\n        if (a[_this.sortKey] > b[_this.sortKey]) return 1 * modifier;\n        return 0;\n      });\n\n      // Pagination\n      return filtered.slice((this.page - 1) * this.itemsPerPage, this.page * this.itemsPerPage);\n    }\n  },\n  methods: {\n    toggleExpand: function toggleExpand(index) {\n      console.log(\"Toggling row:\", index);\n      this.expandedIndex = this.expandedIndex === index ? null : index;\n    },\n    sortBy: function sortBy(key) {\n      this.sortOrder = this.sortKey === key ? this.sortOrder === \"asc\" ? \"desc\" : \"asc\" : \"asc\";\n      this.sortKey = key;\n    },\n    nextPage: function nextPage() {\n      this.page++;\n    },\n    prevPage: function prevPage() {\n      this.page--;\n    }\n  }\n};","map":{"version":3,"names":["props","results","type","Object","default","pages","data","searchQuery","filterType","expandedIndex","page","itemsPerPage","sortKey","sortOrder","computed","filteredResults","_this","filtered","filter","url","includes","title","description","hasHttps","titleCounts","forEach","sort","a","b","modifier","slice","methods","toggleExpand","index","console","log","sortBy","key","nextPage","prevPage"],"sources":["C:\\Users\\RYZEN 5 5500\\Documents\\GitHub\\webdiagnostic-fe-m1\\src\\components\\ValidationResults.vue"],"sourcesContent":["<template>\n  <div class=\"results-container\">\n    <div class=\"scanned-pages\">\n      <h2 class=\"text-lg font-semibold mb-4\">Scanned Pages</h2>\n\n      <!-- Search and Filter -->\n      <div class=\"flex justify-between mb-4\">\n        <input\n          v-model=\"searchQuery\"\n          type=\"text\"\n          placeholder=\"Search URL or Title...\"\n          class=\"border p-2 rounded w-1/3\"\n        />\n        <select v-model=\"filterType\" class=\"border p-2 rounded\">\n          <option value=\"\">All</option>\n          <option value=\"missingDescription\">Missing Description</option>\n          <option value=\"noHttps\">No HTTPS</option>\n          <option value=\"duplicateTitle\">Duplicate Title</option>\n        </select>\n      </div>\n\n      <!-- Table -->\n      <div class=\"overflow-auto border rounded-lg shadow-md\">\n        <table class=\"w-full\">\n          <thead class=\"bg-gray-100 sticky top-0\">\n            <tr>\n              <th @click=\"sortBy('url')\" class=\"px-4 py-2 cursor-pointer\">\n                URL\n              </th>\n              <th @click=\"sortBy('title')\" class=\"px-4 py-2 cursor-pointer\">\n                Title\n              </th>\n              <th class=\"px-4 py-2\">Title Length</th>\n              <th class=\"px-4 py-2\">Description</th>\n              <th class=\"px-4 py-2\">Description Length</th>\n              <th @click=\"sortBy('hasHttps')\" class=\"px-4 py-2 cursor-pointer\">\n                HTTPS\n              </th>\n              <th class=\"px-4 py-2\">Copyright</th>\n              <th class=\"px-4 py-2\">Contact Info</th>\n            </tr>\n          </thead>\n          <tbody>\n            <template v-for=\"(page, index) in filteredResults\" :key=\"index\">\n              <!-- Main row -->\n              <tr\n                @click=\"toggleExpand(index)\"\n                class=\"cursor-pointer border-b hover:bg-gray-50\"\n              >\n                <td class=\"px-4 py-2\">\n                  <a\n                    :href=\"page.url\"\n                    target=\"_blank\"\n                    class=\"text-blue-500 underline\"\n                    >{{ page.url }}</a\n                  >\n                </td>\n                <td class=\"px-4 py-2\">{{ page.title }}</td>\n                <td class=\"px-4 py-2\">{{ page.title_length }}</td>\n                <td class=\"px-4 py-2\">{{ page.description }}</td>\n                <td class=\"px-4 py-2\">\n                  <span\n                    :class=\"{\n                      'text-green-500': page.description_length > 50,\n                      'text-red-500': !page.description,\n                    }\"\n                  >\n                    {{ page.description_length || \"Missing\" }}\n                  </span>\n                </td>\n                <td class=\"px-4 py-2\">\n                  <span\n                    :class=\"{\n                      'text-green-500': page.hasHttps === 'Yes',\n                      'text-red-500': page.hasHttps === 'No',\n                    }\"\n                  >\n                    {{ page.hasHttps }}\n                  </span>\n                </td>\n                <td class=\"px-4 py-2\">{{ page.copyright }}</td>\n                <td class=\"px-4 py-2\">\n                  <p><strong>Address:</strong> {{ page.address }}</p>\n                  <p><strong>Phone:</strong> {{ page.phone }}</p>\n                  <p><strong>Email:</strong> {{ page.email }}</p>\n                </td>\n              </tr>\n\n              <!-- Expandable Row (fixed scope) -->\n              <tr\n                v-if=\"expandedIndex === index\"\n                :key=\"'expanded-' + index\"\n                class=\"bg-blue-50\"\n              >\n                <td colspan=\"8\" class=\"px-4 py-3\">\n                  <div class=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <p class=\"font-semibold text-gray-700 mb-2\">\n                        SEO Validation Summary:\n                      </p>\n                      <ul class=\"space-y-1 text-sm\">\n                        <li>\n                          <span class=\"font-medium\">Title Length:</span>\n                          <span\n                            :class=\"{\n                              'text-green-600': page.is_title_ideal,\n                              'text-yellow-500': page.is_title_too_short,\n                              'text-red-600':\n                                !page.is_title_ideal &&\n                                !page.is_title_too_short,\n                            }\"\n                          >\n                            {{ page.title_length }} characters\n                            <span v-if=\"page.is_title_ideal\">(Ideal)</span>\n                            <span v-else-if=\"page.is_title_too_short\"\n                              >(Too short)</span\n                            >\n                            <span v-else>(Too long)</span>\n                          </span>\n                        </li>\n\n                        <li>\n                          <span class=\"font-medium\">Meta Description:</span>\n                          <span\n                            :class=\"{\n                              'text-green-600':\n                                !page.is_description_missing &&\n                                !page.is_description_duplicate,\n                              'text-red-600': page.is_description_missing,\n                              'text-yellow-500': page.is_description_duplicate,\n                            }\"\n                          >\n                            <span v-if=\"page.is_description_missing\"\n                              >Missing</span\n                            >\n                            <span v-else-if=\"page.is_description_duplicate\"\n                              >Duplicate</span\n                            >\n                            <span v-else\n                              >Valid ({{\n                                page.description_length\n                              }}\n                              characters)</span\n                            >\n                          </span>\n                        </li>\n\n                        <li>\n                          <span class=\"font-medium\">HTTPS:</span>\n                          <span\n                            :class=\"{\n                              'text-green-600': page.hasHttps === 'Yes',\n                              'text-red-600': page.hasHttps === 'No',\n                            }\"\n                          >\n                            {{\n                              page.hasHttps === \"Yes\"\n                                ? \"Secure (HTTPS)\"\n                                : \"Not Secure (No HTTPS)\"\n                            }}\n                          </span>\n                        </li>\n\n                        <li>\n                          <span class=\"font-medium\">Title Duplicate:</span>\n                          <span\n                            :class=\"\n                              page.is_title_duplicate\n                                ? 'text-red-600'\n                                : 'text-green-600'\n                            \"\n                          >\n                            {{ page.is_title_duplicate ? \"Yes\" : \"No\" }}\n                          </span>\n                        </li>\n                      </ul>\n                    </div>\n\n                    <div>\n                      <p class=\"font-semibold text-gray-700 mb-2\">\n                        Suggestions:\n                      </p>\n                      <ul class=\"list-disc list-inside text-sm\">\n                        <li v-if=\"page.is_title_too_short\">\n                          Consider expanding your title to 50–60 characters.\n                        </li>\n                        <li v-if=\"!page.title && !page.is_title_too_short\">\n                          Review your title length.\n                        </li>\n                        <li v-if=\"page.is_description_missing\">\n                          Add a meta description to improve SEO.\n                        </li>\n                        <li v-if=\"page.is_description_duplicate\">\n                          Make the description unique per page.\n                        </li>\n                        <li v-if=\"page.hasHttps !== 'Yes'\">\n                          Enable HTTPS for better security and ranking.\n                        </li>\n                      </ul>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n            </template>\n          </tbody>\n        </table>\n      </div>\n\n      <!-- Pagination -->\n      <div class=\"flex justify-between items-center mt-4\">\n        <button\n          @click=\"prevPage\"\n          :disabled=\"page === 1\"\n          class=\"px-3 py-1 border rounded\"\n        >\n          Previous\n        </button>\n        <span>Page {{ page }}</span>\n        <button\n          @click=\"nextPage\"\n          :disabled=\"page * itemsPerPage >= results.pages.length\"\n          class=\"px-3 py-1 border rounded\"\n        >\n          Next\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  props: {\n    results: {\n      type: Object,\n      default: () => ({ pages: [] }),\n    },\n  },\n  data() {\n    return {\n      searchQuery: \"\",\n      filterType: \"\",\n      expandedIndex: null,\n      page: 1,\n      itemsPerPage: 10,\n      sortKey: \"url\",\n      sortOrder: \"asc\",\n    };\n  },\n  computed: {\n    filteredResults() {\n      let filtered = this.results.pages;\n\n      // Search Query\n      if (this.searchQuery) {\n        filtered = filtered.filter(\n          (page) =>\n            page.url.includes(this.searchQuery) ||\n            page.title.includes(this.searchQuery)\n        );\n      }\n\n      // Filtering\n      if (this.filterType === \"missingDescription\") {\n        filtered = filtered.filter((page) => !page.description);\n      } else if (this.filterType === \"noHttps\") {\n        filtered = filtered.filter((page) => page.hasHttps === \"No\");\n      } else if (this.filterType === \"duplicateTitle\") {\n        const titleCounts = {};\n        filtered.forEach((page) => {\n          titleCounts[page.title] = (titleCounts[page.title] || 0) + 1;\n        });\n        filtered = filtered.filter((page) => titleCounts[page.title] > 1);\n      }\n\n      // Sorting\n      filtered.sort((a, b) => {\n        let modifier = this.sortOrder === \"asc\" ? 1 : -1;\n        if (a[this.sortKey] < b[this.sortKey]) return -1 * modifier;\n        if (a[this.sortKey] > b[this.sortKey]) return 1 * modifier;\n        return 0;\n      });\n\n      // Pagination\n      return filtered.slice(\n        (this.page - 1) * this.itemsPerPage,\n        this.page * this.itemsPerPage\n      );\n    },\n  },\n  methods: {\n    toggleExpand(index) {\n      console.log(\"Toggling row:\", index);\n      this.expandedIndex = this.expandedIndex === index ? null : index;\n    },\n    sortBy(key) {\n      this.sortOrder =\n        this.sortKey === key\n          ? this.sortOrder === \"asc\"\n            ? \"desc\"\n            : \"asc\"\n          : \"asc\";\n      this.sortKey = key;\n    },\n    nextPage() {\n      this.page++;\n    },\n    prevPage() {\n      this.page--;\n    },\n  },\n};\n</script>\n\n<style scoped>\nth,\ntd {\n  padding: 10px;\n  text-align: left;\n}\n</style>\n"],"mappings":";;;;;;;;;;;;;AAyOA,eAAe;EACbA,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZ,WAAS,SAATC,QAAOA,CAAA;QAAA,OAAS;UAAEC,KAAK,EAAE;QAAG,CAAC;MAAA;IAC/B;EACF,CAAC;EACDC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE,EAAE;MACfC,UAAU,EAAE,EAAE;MACdC,aAAa,EAAE,IAAI;MACnBC,IAAI,EAAE,CAAC;MACPC,YAAY,EAAE,EAAE;MAChBC,OAAO,EAAE,KAAK;MACdC,SAAS,EAAE;IACb,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,eAAe,WAAfA,eAAeA,CAAA,EAAG;MAAA,IAAAC,KAAA;MAChB,IAAIC,QAAO,GAAI,IAAI,CAAChB,OAAO,CAACI,KAAK;;MAEjC;MACA,IAAI,IAAI,CAACE,WAAW,EAAE;QACpBU,QAAO,GAAIA,QAAQ,CAACC,MAAM,CACxB,UAACR,IAAI;UAAA,OACHA,IAAI,CAACS,GAAG,CAACC,QAAQ,CAACJ,KAAI,CAACT,WAAW,KAClCG,IAAI,CAACW,K