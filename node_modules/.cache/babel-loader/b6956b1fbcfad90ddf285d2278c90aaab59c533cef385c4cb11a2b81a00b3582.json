{"ast":null,"code":"import { ref, computed } from \"vue\";\nimport { useRoute } from \"vue-router\";\nexport default {\n  data: function data() {\n    return {\n      isCollapsed: false\n    };\n  },\n  setup: function setup() {\n    var route = useRoute();\n\n    // ✅ Check if user is authenticated\n    var isAuthenticated = computed(function () {\n      return !!sessionStorage.getItem(\"token\");\n    });\n    // Show SideNavigation and Header only if the route is not '/login'\n    var showSideNavigation = computed(function () {\n      return route.path !== \"/\";\n    });\n    // State for collapsing SideNavigation\n    var isSideNavCollapsed = ref(false);\n    var toggleSideNavigation = function toggleSideNavigation() {\n      isSideNavCollapsed.value = !isSideNavCollapsed.value;\n    };\n    return {\n      showSideNavigation: showSideNavigation,\n      isSideNavCollapsed: isSideNavCollapsed,\n      toggleSideNavigation: toggleSideNavigation,\n      isAuthenticated: isAuthenticated\n    };\n  }\n};","map":{"version":3,"names":["ref","computed","useRoute","data","isCollapsed","setup","route","isAuthenticated","sessionStorage","getItem","showSideNavigation","path","isSideNavCollapsed","toggleSideNavigation","value"],"sources":["C:\\Users\\Production\\Documents\\GitHub\\webdiagnostic-fe-m1\\src\\App.vue"],"sourcesContent":["<template>\n  <div class=\"app min-h-screen flex flex-col font-sans\">\n    <!-- Main Content -->\n    <div class=\"main-content flex-1 bg-gradient-to-r from-gray-100 to-blue-50\">\n      <router-view />\n    </div>\n  </div>\n</template>\n\n<script>\nimport { ref, computed } from \"vue\";\nimport { useRoute } from \"vue-router\";\nexport default {\n  data() {\n    return {\n      isCollapsed: false,\n    };\n  },\n  setup() {\n    const route = useRoute();\n\n    // ✅ Check if user is authenticated\n    const isAuthenticated = computed(() => !!sessionStorage.getItem(\"token\"));\n    // Show SideNavigation and Header only if the route is not '/login'\n    const showSideNavigation = computed(() => route.path !== \"/\");\n    // State for collapsing SideNavigation\n    const isSideNavCollapsed = ref(false);\n    const toggleSideNavigation = () => {\n      isSideNavCollapsed.value = !isSideNavCollapsed.value;\n    };\n\n    return {\n      showSideNavigation,\n      isSideNavCollapsed,\n      toggleSideNavigation,\n      isAuthenticated,\n    };\n  },\n};\n</script>\n\n<style lang=\"scss\">\n.app {\n  display: flex;\n  flex-direction: column; /* Stack header at the top */\n  min-height: 100vh; /* Full height for the app */\n}\n\n.main-layout {\n  display: flex;\n  flex: 1; /* Occupy the remaining space after the header */\n}\n\n.main-content {\n  flex: 1; /* Occupy the rest of the space after SideNavigation */\n  transition: margin-left 0.3s ease-in-out;\n}\n\n.main-content.ml-16 {\n  margin-left: 4rem; /* Adjust main content margin when SideNavigation is collapsed */\n}\n</style>\n"],"mappings":"AAUA,SAASA,GAAG,EAAEC,QAAO,QAAS,KAAK;AACnC,SAASC,QAAO,QAAS,YAAY;AACrC,eAAe;EACbC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE;IACf,CAAC;EACH,CAAC;EACDC,KAAK,WAALA,KAAKA,CAAA,EAAG;IACN,IAAMC,KAAI,GAAIJ,QAAQ,CAAC,CAAC;;IAExB;IACA,IAAMK,eAAc,GAAIN,QAAQ,CAAC;MAAA,OAAM,CAAC,CAACO,cAAc,CAACC,OAAO,CAAC,OAAO,CAAC;IAAA,EAAC;IACzE;IACA,IAAMC,kBAAiB,GAAIT,QAAQ,CAAC;MAAA,OAAMK,KAAK,CAACK,IAAG,KAAM,GAAG;IAAA,EAAC;IAC7D;IACA,IAAMC,kBAAiB,GAAIZ,GAAG,CAAC,KAAK,CAAC;IACrC,IAAMa,oBAAmB,GAAI,SAAvBA,oBAAmBA,CAAA,EAAU;MACjCD,kBAAkB,CAACE,KAAI,GAAI,CAACF,kBAAkB,CAACE,KAAK;IACtD,CAAC;IAED,OAAO;MACLJ,kBAAkB,EAAlBA,kBAAkB;MAClBE,kBAAkB,EAAlBA,kBAAkB;MAClBC,oBAAoB,EAApBA,oBAAoB;MACpBN,eAAe,EAAfA;IACF,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}