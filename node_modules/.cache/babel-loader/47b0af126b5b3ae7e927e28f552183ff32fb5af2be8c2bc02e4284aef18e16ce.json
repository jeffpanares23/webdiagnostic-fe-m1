class=\"p-2\">Title Length</th>\n              <th class=\"p-2\">Title Status\n                <select v-model=\"columnFilters.titleStatus\" class=\"mt-1 w-full border rounded\">\n                  <option value=\"\">All</option>\n                  <option value=\"ideal\">Ideal</option>\n                  <option value=\"short\">Too Short</option>\n                  <option value=\"long\">Too Long</option>\n                </select>\n              </th>\n              <th class=\"p-2\">Meta Description</th>\n              <th class=\"p-2\">Meta Length</th>\n              <th class=\"p-2\">Meta Status\n                <select v-model=\"columnFilters.metaStatus\" class=\"mt-1 w-full border rounded\">\n                  <option value=\"\">All</option>\n                  <option value=\"valid\">Valid</option>\n                  <option value=\"missing\">Missing</option>\n                  <option value=\"duplicate\">Duplicate</option>\n                </select>\n              </th>\n              <th class=\"p-2\">HTTPS\n                <select v-model=\"columnFilters.https\" class=\"mt-1 w-full border rounded\">\n                  <option value=\"\">All</option>\n                  <option value=\"Yes\">Yes</option>\n                  <option value=\"No\">No</option>\n                </select>\n              </th>\n              <th class=\"p-2\">Duplicate Title\n                <select v-model=\"columnFilters.duplicateTitle\" class=\"mt-1 w-full border rounded\">\n                  <option value=\"\">All</option>\n                  <option value=\"Yes\">Yes</option>\n                  <option value=\"No\">No</option>\n                </select>\n              </th>\n              <th class=\"p-2\">Phone</th>\n              <th class=\"p-2\">Email</th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr v-for=\"(page, index) in filteredResults\" :key=\"index\" class=\"border-b hover:bg-gray-50\">\n              <td class=\"p-2 text-center\">{{ index + 1 }}</td>\n              <td class=\"p-2 break-words max-w-[200px]\">\n                <a :href=\"page.url\" target=\"_blank\" class=\"text-blue-600 underline\">{{ page.url }}</a>\n              </td>\n              <td class=\"p-2\">{{ page.title }}</td>\n              <td class=\"p-2 text-center\">{{ page.title_length }}</td>\n              <td class=\"p-2 text-center\">\n                <span :class=\"titleStatusClass(page)\">{{ getTitleStatus(page) }}</span>\n              </td>\n              <td class=\"p-2\">{{ page.description }}</td>\n              <td class=\"p-2 text-center\">{{ page.description_length || '—' }}</td>\n              <td class=\"p-2 text-center\">\n                <span :class=\"metaStatusClass(page)\">{{ getMetaStatus(page) }}</span>\n              </td>\n              <td class=\"p-2 text-center\">\n                <span :class=\"page.hasHttps === 'Yes' ? 'text-green-600' : 'text-red-600'\">\n                  {{ page.hasHttps }}\n                </span>\n              </td>\n              <td class=\"p-2 text-center\">\n                <span :class=\"page.is_title_duplicate ? 'text-red-600' : 'text-green-600'\">\n                  {{ page.is_title_duplicate ? 'Yes' : 'No' }}\n                </span>\n              </td>\n              <td class=\"p-2\">{{ page.phone }}</td>\n              <td class=\"p-2\">{{ page.email }}</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      <!-- Summary and Export -->\n      <div class=\"flex justify-between items-center mt-4 px-2 py-1 bg-gray-100 border text-xs\">\n        <div>Total Pages: {{ results.pages.length }}</div>\n        <div>\n          Errors: {{ errorCount }} | Warnings: {{ warningCount }} | Valid: {{ validCount }}\n        </div>\n        <button @click=\"exportCSV\" class=\"bg-green-500 text-white px-3 py-1 rounded hover:bg-green-600\">\n          Export CSV (Filtered)\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  props: {\n    results: {\n      type: Object,\n      default: () => ({ pages: [] }),\n    },\n  },\n  data() {\n    return {\n      columnFilters: {\n        titleStatus: '',\n        metaStatus: '',\n        https: '',\n        duplicateTitle: '',\n      },\n    };\n  },\n  computed: {\n    filteredResults() {\n      return this.results.pages.filter((page) => {\n        // Title Status Filter\n        const titleStatus = this.getTitleStatus(page).toLowerCase();\n        if (this.columnFilters.titleStatus && titleStatus !== this.columnFilters.titleStatus) return false;\n\n        // Meta Status Filter\n        const metaStatus = this.getMetaStatus(page).toLowerCase();\n        if (this.columnFilters.metaStatus && metaStatus !== this.columnFilters.metaStatus) return false;\n\n        // HTTPS Filter\n        if (this.columnFilters.https && page.hasHttps !== this.columnFilters.https) return false;\n\n        // Duplicate Title Filter\n        const dup = page.is_title_duplicate ? 'Yes' : 'No';\n        if (this.columnFilters.duplicateTitle && dup !== this.columnFilters.duplicateTitle) return false;\n\n        return true;\n      });\n    },\n    errorCount() {\n      return this.filteredResults.filter((p) => p.is_description_missing || (!p.is_title_ideal && !p.is_title_too_short) || p.hasHttps === 'No').length;\n    },\n    warningCount() {\n      return this.filteredResults.filter((p) => p.is_title_too_short || p.is_description_duplicate).length;\n    },\n    validCount() {\n      return this.filteredResults.length - this.errorCount - this.warningCount;\n    },\n  },\n  methods: {\n    getTitleStatus(page) {\n      if (page.is_title_ideal) return 'Ideal';\n      if (page.is_title_too_short) return 'Too Short';\n      return 'Too Long';\n    },\n    getMetaStatus(page) {\n      if (page.is_description_missing) return 'Missing';\n      if (page.is_description_duplicate) return 'Duplicate';\n      return 'Valid';\n    },\n    titleStatusClass(page) {\n      return {\n        'text-green-600': page.is_title_ideal,\n        'text-yellow-500': page.is_title_too_short,\n        'text-red-600': !page.is_title_ideal && !page.is_title_too_short,\n      };\n    },\n    metaStatusClass(page) {\n      return {\n        'text-green-600': !page.is_description_missing && !page.is_description_duplicate,\n        'text-yellow-500': page.is_description_duplicate,\n        'text-red-600': page.is_description_missing,\n      };\n    },\n    exportCSV() {\n      const rows = [\n        [\n          'URL',\n          'Title',\n          'Title Length',\n          'Title Status',\n          'Meta Description',\n          'Meta Length',\n          'Meta Status',\n          'HTTPS',\n          'Duplicate Title',\n          'Phone',\n          'Email'\n        ],\n        ...this.filteredResults.map((page) => [\n          page.url,\n          page.title,\n          page.title_length,\n          this.getTitleStatus(page),\n          page.description,\n          page.description_length,\n          this.getMetaStatus(page),\n          page.hasHttps,\n          page.is_title_duplicate ? 'Yes' : 'No',\n          page.phone,\n          page.email\n        ])\n      ];\n      const csvContent = 'data:text/csv;charset=utf-8,' + rows.map(e => e.map(cell => `\"${cell}\"`).join(',')).join('\\n');\n      const link = document.createElement('a');\n      link.setAttribute('href', encodeURI(csvContent));\n      link.setAttribute('download', 'validation_results.csv');\n      document.body.appendChild(link);\n      link.click();\n      document.body.removeChild(link);\n    },\n  },\n};\n</script>\n\n<style scoped>\nth, td {\n  white-space: nowrap;\n}\n</style>\n"],"mappings":";;;;;;;;;;;AAkGA,eAAe;EACbA,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZ,WAAS,SAATC,QAAOA,CAAA;QAAA,OAAS;UAAEC,KAAK,EAAE;QAAG,CAAC;MAAA;IAC/B;EACF,CAAC;EACDC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,aAAa,EAAE;QACbC,WAAW,EAAE,EAAE;QACfC,UAAU,EAAE,EAAE;QACdC,KAAK,EAAE,EAAE;