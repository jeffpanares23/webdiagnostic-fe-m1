his.results.pages.filter(function (p) {\n        return p.is_description_missing || !p.is_title_ideal && !p.is_title_too_short || p.hasHttps === \"No\";\n      }).length;\n      var warnings = this.results.pages.filter(function (p) {\n        return p.is_title_too_short || p.is_description_duplicate;\n      }).length;\n      var valid = this.results.pages.length - errors - warnings;\n      return {\n        labels: [\"Valid\", \"Warnings\", \"Errors\"],\n        datasets: [{\n          data: [valid, warnings, errors],\n          backgroundColor: [\"#22c55e\", \"#facc15\", \"#ef4444\"]\n        }]\n      };\n    },\n    hasIssues: function hasIssues() {\n      // return this.currentPage.issues && this.currentPage.issues.length > 0;\n      return this.filteredIssuesToFix.length > 0;\n    },\n    allIssues: function allIssues() {\n      if (!this.results.pages) return [];\n      return this.results.pages.flatMap(function (page) {\n        return page.issues || [];\n      });\n    },\n    // metadataIssues() {\n    //   console.log(this.results.issues);\n    //   return this.results.issues?.filter((i) => i.section === \"metadata\") || [];\n    // },\n    // sopIssues() {\n    //   return this.results.issues?.filter((i) => i.section === \"sop\") || [];\n    // },\n    metadataIssues: function metadataIssues() {\n      if (!this.currentPage || !this.currentPage.issues) return [];\n      return this.currentPage.issues.filter(function (i) {\n        return i.section === \"metadata\";\n      });\n    },\n    sopIssues: function sopIssues() {\n      if (!this.currentPage || !this.currentPage.issues) return [];\n      return this.currentPage.issues.filter(function (i) {\n        return i.section === \"sop\";\n      });\n    }\n  },\n  methods: {\n    // selectPage(index) {\n    //   this.selectedPage = index;\n    //   localStorage.setItem(\"selectedPageIndex\", index);\n    // },\n    getExplanation: function getExplanation(issue) {\n      return issue.explanation || \"\";\n    },\n    selectPage: function selectPage(index) {\n      var page = this.filteredResults[index];\n      if (!page) {\n        console.warn(\"Selected page not found in filteredResults.\");\n        return;\n      }\n      var originalIndex = this.results.pages.findIndex(function (p) {\n        return p.url === page.url;\n      });\n      if (originalIndex !== -1) {\n        this.selectedPage = originalIndex;\n        localStorage.setItem(\"selectedPageIndex\", originalIndex);\n      } else {\n        console.warn(\"Page not found in original results.pages.\");\n      }\n    },\n    exportToCSV: function exportToCSV() {\n      var rows = this.filteredResults.map(function (page) {\n        var _page$sop, _page$sop2, _page$sop3, _page$sop4, _page$sop5;\n        return {\n          URL: page.url,\n          Title: page.title,\n          MetaDescription: page.description,\n          HTTPS: page.hasHttps,\n          DuplicateTitle: page.is_title_duplicate ? \"Yes\" : \"No\",\n          Phone: page.phone,\n          Email: page.email,\n          company_name: page.company_name,\n          PhoneFormatValid: (_page$sop = page.sop) !== null && _page$sop !== void 0 && _page$sop.phone_format_valid ? \"Yes\" : \"No\",\n          EmailFormatValid: (_page$sop2 = page.sop) !== null && _page$sop2 !== void 0 && _page$sop2.email_format_valid ? \"Yes\" : \"No\",\n          AddressFormatValid: (_page$sop3 = page.sop) !== null && _page$sop3 !== void 0 && _page$sop3.address_format_valid ? \"Yes\" : \"No\",\n          CompanyNameValid: (_page$sop4 = page.sop) !== null && _page$sop4 !== void 0 && _page$sop4.company_name_valid ? \"Yes\" : \"No\",\n          CopyrightValid: (_page$sop5 = page.sop) !== null && _page$sop5 !== void 0 && _page$sop5.copyright_year_valid ? \"Yes\" : \"No\"\n        };\n      });\n      var csv = [Object.keys(rows[0]).join(\",\")].concat(_toConsumableArray(rows.map(function (row) {\n        return Object.values(row).map(function (val) {\n          return \"\\\"\".