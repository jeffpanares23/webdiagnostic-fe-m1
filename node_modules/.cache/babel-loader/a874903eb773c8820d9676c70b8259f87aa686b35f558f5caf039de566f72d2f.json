n    <!-- 📌 Sidebar Toggle Button for Mobile -->\n    <button\n      class=\"lg:hidden bg-blue-500 text-white px-4 py-2 rounded-md mb-4\"\n      @click=\"sidebarOpen = !sidebarOpen\"\n    >\n      ☰ History\n    </button>\n\n    <!-- 📌 Overlay when Sidebar is Open -->\n    <div\n      v-if=\"sidebarOpen\"\n      class=\"sidebar-overlay\"\n      @click=\"sidebarOpen = false\"\n    ></div>\n\n    <!-- 📌 Sidebar Drawer -->\n    <!-- <div\n      class=\"lg:w-1/4 w-full shadow-md lg:relative fixed inset-y-0 left-0 z-20 h-full overflow-y-auto bg-white transform transition-transform lg:translate-x-0\"\n      :class=\"{\n        '-translate-x-full': !sidebarOpen,\n        'translate-x-0': sidebarOpen,\n      }\"\n    >\n      <button\n        class=\"lg:hidden absolute top-4 right-4 text-gray-600\"\n        @click=\"sidebarOpen = false\"\n      >\n        ✖\n      </button>\n      <HistorySidebar\n        :history=\"history\"\n        @select=\"handleHistorySelect\"\n        @updateUrl=\"websiteUrl = $event\"\n      />\n    </div> -->\n\n    <!-- 📌 Main Content -->\n    <div class=\"lg:w-3/4 w-full flex-1 p-4 pt-0 container mx-auto space-y-6\">\n      <SubNavigation />\n\n      <!-- 📌 Improved Search Input -->\n      <WebsiteInput\n        class=\"input-box\"\n        placeholder=\"Enter website URL...\"\n        @loading=\"setLoading\"\n        @results=\"handleResults\"\n        v-model=\"websiteUrl\"\n      />\n\n      <!-- 📌 Tabs Navigation -->\n      <div v-if=\"results\">\n        <div class=\"tabs flex space-x-4 border-b\">\n          <button\n            v-for=\"tab in tabs\"\n            :key=\"tab\"\n            class=\"tab\"\n            :class=\"{ active: activeTab === tab }\"\n            @click=\"activeTab = tab\"\n          >\n            {{ tab }}\n          </button>\n        </div>\n      </div>\n\n      <!-- 📌 Tab Content -->\n      <div v-if=\"activeTab === 'Results'\">\n        <ValidationResults v-if=\"results\" :results=\"results\" />\n        <ExportButtons v-if=\"results\" :results=\"results\" />\n      </div>\n\n      <!-- 📌 Empty State Message with Tips -->\n      <div v-if=\"!results && !loading\" class=\"text-center mt-10\">\n        <img\n          src=\"@/assets/Web-search.gif\"\n          class=\"w-2/3 md:w-1/3 opacity-75 m-auto\"\n        />\n        <p class=\"text-gray-500 mt-4\">\n          Start diagnosing a website by entering a URL above.\n        </p>\n        <p class=\"text-sm text-gray-400\">Try: www.example.com</p>\n      </div>\n\n      <!-- 📌 Loading Indicator -->\n      <!-- <transition name=\"fade\">\n        <div v-if=\"loading\" class=\"text-center text-gray-500\">\n          Scanning website...\n        </div>\n      </transition> -->\n      <transition name=\"slide-expand\">\n        <div\n          v-if=\"loading\"\n          class=\"w-full bg-blue-50 p-8 flex flex-col justify-center items-center text-center shadow-lg transition-all duration-500\"\n        >\n          <h3 class=\"text-lg font-semibold mb-4\">Analyzing Website Data...</h3>\n          <p class=\"text-gray-600\">{{ loadingInsight }}</p>\n          <div class=\"progress-bar mt-4\">\n            <div class=\"progress\" :style=\"{ width: progress + '%' }\"></div>\n          </div>\n        </div>\n      </transition>\n    </div>\n  </div>\n</template>\n\n<script>\nimport SubNavigation from \"../components/SubNavigation.vue\";\nimport WebsiteInput from \"../components/WebsiteInput.vue\";\nimport ValidationResults from \"../components/ValidationResults.vue\";\nimport ExportButtons from \"../components/ExportButtons.vue\";\nimport HistorySidebar from \"../components/HistorySidebar.vue\";\nimport axios from \"axios\";\nimport baseUrl from \"../config\";\n\nexport default {\n  components: {\n    SubNavigation,\n    WebsiteInput,\n    ValidationResults,\n    ExportButtons,\n    // HistorySidebar,\n  },\n  data() {\n    return {\n      websiteUrl: \"\",\n      loading: false,\n      progress: 0,\n      loadingInsight: \"Initializing...\",\n      insights: [\n        \"Checking server response time...\",\n        \"Verifying SSL security...\",\n        \"Analyzing website load performance...\",\n        \"Scanning SEO metrics...\",\n        \"Optimizing user experience...\",\n      ],\n      results: null,\n      tabs: [\"Results\"],\n      activeTab: \"Results\",\n      history: {},\n      sidebarOpen: false, // 📌 Controls Sidebar Visibility\n    };\n  },\n  mounted() {\n    this.fetchHistory();\n  },\n  computed: {\n    filteredIssues() {\n      // ✅ Ensure `results` exists and `issues` is an array before filtering\n      if (!this.results || !Array.isArray(this.results.issues)) {\n        return []; // Return an empty array if undefined\n      }\n      return this.results.issues.filter((issue) => issue.type === \"error\");\n    },\n  },\n  methods: {\n    async fetchHistory() {\n      const token = localStorage.getItem(\"token\");\n\n      if (!token) {\n        this.errorMessage = \"You are not authenticated. Please log in.\";\n        this.loading = false;\n        return;\n      }\n\n      try {\n        const response = await axios.get(`${baseUrl}/api/diagnostic-history`, {\n          headers: { Authorization: `Bearer ${token}` },\n        });\n        this.history = response.data;\n      } catch (error) {\n        console.error(\n          \"Failed to fetch history:\",\n          error.response?.data || error\n        );\n      }\n    },\n    handleHistorySelect(selectedResult) {\n      this.websiteUrl = selectedResult.url;\n      this.results = selectedResult;\n      this.sidebarOpen = false; // 📌 Close sidebar on mobile after selecting\n    },\n    // handleResults(newResults) {\n    //   this.loading = false;\n    //   this.results = newResults;\n    //   this.fetchHistory();\n    // },\n    handleResults(newResults) {\n      this.loading = false;\n\n      // ✅ Ensure newResults is always valid\n      this.results = {\n        ...newResults,\n        issues: Array.isArray(newResults.issues) ? newResults.issues : [],\n      };\n\n      this.fetchHistory();\n    },\n    setLoading() {\n      this.loading = true;\n      this.startLoadingAnimation();\n    },\n    startLoadingAnimation() {\n      let index = 0;\n      this.progress = 0;\n\n      const interval = setInterval(() => {\n        if (this.progress >= 100) {\n          clearInterval(interval);\n        } else {\n          this.progress += 5;\n          // Rotate through your insights array\n          this.loadingInsight = this.insights[index % this.insights.length];\n          index++;\n        }\n      }, 3000);\n    },\n  },\n};\n</script>\n\n<style scoped>\n/* 📌 Sidebar Overlay */\n.sidebar-overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.5);\n  z-index: 15;\n  transition: opacity 0.3s ease-in-out;\n}\n\n.progress-bar {\n  width: 80%;\n  height: 10px;\n  background: #ddd;\n  border-radius: 5px;\n  overflow: hidden;\n}\n.progress {\n  height: 100%;\n  background: #3498db;\n  transition: width 3s ease;\n}\n\n/* Optional for the slide-expand transition */\n.slide-expand-enter-active,\n.slide-expand-leave-active {\n  transition: all 3s ease;\n}\n.slide-expand-enter-from,\n.slide-expand-leave-to {\n  opacity: 0;\n  transform: translateY(-10px);\n}\n\n/* 📌 Sidebar Drawer Transition for Mobile */\n@media (max-width: 1024px) {\n  .translate-x-0 {\n    transform: translateX(0);\n  }\n  .-translate-x-full {\n    transform: translateX(-100%);\n  }\n}\n\n/* 📌 Improved Search Input */\n.input-box {\n  border: 2px solid #e0e0e0;\n  border-radius: 8px;\n  padding: 10px 14px;\n  transition: all 0.3s ease;\n}\n.input-box:focus {\n  border-color: #3b82f6;\n  box-shadow: 0px 0px 8px rgba(59, 130, 246, 0.3);\n}\n\n/* 📌 Tabs Styling */\n.tab {\n  padding: 10px 16px;\n  border-bottom: 2px solid transparent;\n  transition: all 0.3s ease;\n}\n.tab:hover {\n  background-color: #f9fafb;\n}\n.tab.active {\n  border-bottom: 2px solid #3b82f6;\n  font-weight: bold;\n}\n\n/* 📌 Fade-In Transitions */\n.fade-enter-active,\n.fade-leave-active {\n  transition: opacity 0.3s ease-in-out;\n}\n.fade-enter,\n.fade-leave-to {\n  opacity: 0;\n}\n\n/* 📌 Mobile Optimization */\n@media (max-width: 640px) {\n  .tab {\n    padding: 12px 18px;\n    font-size: 14px;\n  }\n  .input-box {\n    padding: 12px;\n  }\n}\n</style>\n"],"mappings":";OA2EUA,UAA6B;;EA1EhC,SAAM;AAAsC;;EAsC1C,SAAM;AAA6D;;EAvC5EC,GAAA;AAAA;;EAqDa,SAAM;AAA8B;iBArDjD;;EAAAA,GAAA;AAAA;;EAAAA,GAAA;EAyEuC,SAAM;;;EAzE7CA,GAAA;EA6FU,SAAM;;;EAGH,SAAM;AAAe;;EACnB,SAAM;AAAmB;;;;;;uBAhGtCC,mBAAA,CAsGM,OAtGNC,UAsGM,GApGJC,mBAAA,CAKS;IAJP,SAAM,4DAA4D;IACjEC,OAAK,EAAAC,MAAA,QAAAA,MAAA,gBAAAC,MAAA;MAAA,OAAEC,KAAA,CAAAC,WAAW,IAAID,KAAA,CAAAC,WAAW;IAAA;KACnC,aAED,GAIQD,KAAA,CAAAC,WAAW,I,cADnBP,mBAAA,CAIO;IAfXD,GAAA;IAaM,SAAM,iBAAiB;IACtBI,OAAK,EAAAC,MAAA,QAAAA,MAAA,gBAAAC,MAAA;MAAA,OAAEC,KAAA,CAAAC,WAAW;IAAA;QAdzBC,mBAAA,YAuCIN,mBAAA,CA+DM,OA/DNO,UA+DM,GA9DJC,YAAA,CAAiBC,wBAAA,GAGjBD,YAAA,CAMEE,uBAAA;IALA,SAAM,WAAW;IACjBC,WAAW,EAAC,sBAAsB;IACjCC,SAAO,EAAEC,QAAA,CAAAC,UAAU;IACnBC,SAAO,EAAEF,QAAA,CAAAG,aAAa;IA/C/BC,UAAA,EAgDiBb,KAAA,CAAAc,UAAU;IAhD3B,uBAAAhB,MAAA,QAAAA,MAAA,gBAAAC,MAAA;MAAA,OAgDiBC,KAAA,CAAAc,UAAU,GAAAf,MAAA;IAAA;yDAIVC,KAAA,CAAAe,OAAO,I,cAAlBrB,mBAAA,CAYM,OAhEZsB,UAAA,GAqDQpB,mBAAA,CAUM,OAVNqB,UAUM,I,kBATJvB,mBAAA,CAQSwB,SAAA,QA9DnBC,WAAA,CAuD0BnB,KAAA,CAAAoB,IAAI,EAvD9B,UAuDmBC,GAAG;yBADZ3B,mBAAA,CAQS;MANND,GAAG,EAAE4B,GAAG;MACT,SAzDZC,eAAA,EAyDkB,KAAK;QAAAC,MAAA,EACOvB,KAAA,CAAAwB,SAAS,KAAKH;MAAG;MAClCxB,OAAK,WAALA,OAAKA,CAAAE,MAAA;QAAA,OAAEC,KAAA,CAAAwB,SAAS,GAAGH,GAAG;MAAA;wBAEpBA,GAAG,OA7DlBI,UAAA;mBAAAvB,mBAAA,YAmEiBF,KAAA,CAAAwB,SAAS,kB,cAApB9B,mBAAA,CAGM,OAtEZgC,UAAA,GAoEiC1B,KAAA,CAAAe,OAAO,I,cAAhCY,YAAA,CAAuDC,4BAAA;IApE/DnC,GAAA;IAoE2CsB,OAAO,EAAEf,KAAA,CAAAe;8BApEpDb,mBAAA,YAqE6BF,KAAA,CAAAe,OAAO,I,cAA5BY,YAAA,CAAmDE,wBAAA;IArE3DpC,GAAA;IAqEuCsB,OAAO,EAAEf,KAAA,CAAAe;8BArEhDb,mBAAA,W,KAAAA,mBAAA,Y,CAyEkBF,KAAA,CAAAe,OAAO,KAAKf,KAAA,CAAA8B,OAAO,I,cAA/BpC,mBAAA,CASM,OATNqC,UASM,EAAAjC,M