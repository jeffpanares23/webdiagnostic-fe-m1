 formattedUrl = \"http://\" + formattedUrl;\r\n      }\r\n\r\n      const token = localStorage.getItem(\"token\");\r\n\r\n      if (!token) {\r\n        this.errorMessage = \"You are not authenticated. Please log in.\";\r\n        this.loading = false;\r\n        return;\r\n      }\r\n\r\n      try {\r\n        const response = await axios.post(\r\n          `${baseUrl}/api/analyze-website`,\r\n          { url: formattedUrl },\r\n          {\r\n            headers: {\r\n              Authorization: `Bearer ${token}`,\r\n            },\r\n          }\r\n        );\r\n\r\n        if (!response.data || response.data.error) {\r\n          throw new Error(\r\n            response.data.error || \"Invalid response from server.\"\r\n          );\r\n        }\r\n\r\n        console.log(response.data);\r\n\r\n        // const pagesData = response.data.pages.map((page) => ({\r\n        //   url: page.url,\r\n        //   title: page.title || \"N/A\",\r\n        //   title_length: page.title_length || \"N/A\",\r\n        //   description: page.description || \"N/A\",\r\n        //   description_length: page.description_length || \"N/A\",\r\n        //   hasHttps: page.hasHttps ? \"Yes\" : \"No\",\r\n        //   address: page.address || \"N/A\",\r\n        //   phone: page.phone_number || \"N/A\",\r\n        //   email: page.email_address || \"N/A\",\r\n        // }));\r\n\r\n        const pagesData = response.data.pages.map((page) => ({\r\n          url: page.url,\r\n          title: page.title || \"N/A\",\r\n          title_length: page.title_length || \"N/A\",\r\n          description: page.description || \"N/A\",\r\n          description_length: page.description_length || \"N/A\",\r\n          hasHttps: page.hasHttps ? \"Yes\" : \"No\",\r\n          address: page.address || \"N/A\",\r\n          phone: page.phone_number || \"N/A\",\r\n          email: page.email_address || \"N/A\",\r\n          company_name: page.company_name || \"N/A\",\r\n          copyright: page.copyright || \"N/A\",\r\n          sop: page.sop || {},\r\n          issues: page.issues || [],\r\n        }));\r\n\r\n        // Emit all pages data\r\n        this.$emit(\"results\", { pages: pagesData });\r\n      } catch (error) {\r\n        this.errorMessage =\r\n          error.response?.data?.error ||\r\n          \"An error occurred while processing the URL.\";\r\n        console.error(\"API Error:\", error);\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n  },\r\n};\r\n</script>\r\n"],"mappings":";;EACO,SAAM;AAAmC;;EAEvC,SAAM;AAAmC;iBAHlD;;EAAAA,GAAA;AAAA;;EAAAA,GAAA;EAkBqB,SAAM;;;EAlB3BA,GAAA;EA2C2B,SAAM;;;uBA1C/BC,mBAAA,CA2CM,OA3CNC,UA2CM,G,0BA1CJC,mBAAA,CAA0D;IAAtD,SAAM;EAA4B,GAAC,gBAAc,sBACrDA,mBAAA,CAuCM,OAvCNC,UAuCM,G,gBAtCJD,mBAAA,CAME;IAVR,uBAAAE,MAAA,QAAAA,MAAA,gBAAAC,MAAA;MAAA,OAKiBC,QAAA,CAAAC,UAAU,GAAAF,MAAA;IAAA;IACnBG,IAAI,EAAC,KAAK;IACV,SAAM,oDAAoD;IAC1DC,WAAW,EAAC,8BAA8B;IAC1CC,QAAQ,EAAR;iDAJSJ,QAAA,CAAAC,UAAU,E,GAMrBL,mBAAA,CA8BS;IA7BPM,IAAI,EAAC,QAAQ;IACZG,OAAK,EAAAP,MAAA,QAAAA,MAAA;MAAA,OAAEE,QAAA,CAAAM,SAAA,IAAAN,QAAA,CAAAM,SAAA,CAAAC,KAAA,CAAAP,QAAA,EAAAQ,SAAA,CAAS;IAAA;IACjB,SAAM,yFAAyF;IAC9FC,QAAQ,EAAEC,KAAA,CAAAC;OAEED,KAAA,CAAAC,OAAO,I,cAApBjB,mBAAA,CAAgC,QAjBxCkB,UAAA,EAiB8B,KAAG,M,cACzBlB,mBAAA,CAsBO,QAtBPmB,UAsBO,EAAAf,MAAA,QAAAA,MAAA,OArBLF,mBAAA,CAmBM;IAlBJ,SAAM,sCAAsC;IAC5CkB,KAAK,EAAC,4BAA4B;IAClCC,IAAI,EAAC,MAAM;IACXC,OAAO,EAAC;MAERpB,mBAAA,CAOU;IANR,SAAM,YAAY;IAClBqB,EAAE,EAAC,IAAI;IACPC,EAAE,EAAC,IAAI;IACPC,CAAC,EAAC,IAAI;IACNC,MAAM,EAAC,cAAc;IACrB,cAAY,EAAC;MAEfxB,mBAAA,CAIQ;IAHN,SAAM,YAAY;IAClBmB,IAAI,EAAC,cAAc;IACnBM,CAAC,EAAC;0BApChBC,gBAAA,CAsCgB,cAER,E,qBAxCRC,UAAA,E,GA2Cab,KAAA,CAAAc,YAAY,I,cAArB9B,mBAAA,CAAuE,KAAvE+B,UAAuE,EAAAC,gBAAA,CAAnBhB,KAAA,CAAAc,YAAY,oBA3CpEG,mBAAA,e","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}