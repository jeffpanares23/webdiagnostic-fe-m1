{"ast":null,"code":"import { ref, computed } from \"vue\";\nimport { useRoute } from \"vue-router\";\nexport default {\n  data: function data() {\n    return {\n      isCollapsed: false\n    };\n  },\n  setup: function setup() {\n    var route = useRoute();\n\n    // ✅ Check if user is authenticated\n    var isAuthenticated = computed(function () {\n      return !!localStorage.getItem(\"token\");\n    });\n    // Show SideNavigation and Header only if the route is not '/login'\n    var showSideNavigation = computed(function () {\n      return route.path !== \"/\";\n    });\n    // State for collapsing SideNavigation\n    var isSideNavCollapsed = ref(false);\n    var toggleSideNavigation = function toggleSideNavigation() {\n      isSideNavCollapsed.value = !isSideNavCollapsed.value;\n    };\n    return {\n      showSideNavigation: showSideNavigation,\n      isSideNavCollapsed: isSideNavCollapsed,\n      toggleSideNavigation: toggleSideNavigation,\n      isAuthenticated: isAuthenticated\n    };\n  }\n};","map":{"version":3,"names":["ref","computed","useRoute","data","isCollapsed","setup","route","isAuthenticated","localStorage","getItem","showSideNavigation","path","isSideNavCollapsed","toggleSideNavigation","value"],"sources":["C:\\Users\\RYZEN 5 5500\\Documents\\GitHub\\webdiagnostic-fe-m1\\src\\App.vue"],"sourcesContent":["<template>\r\n  <div class=\"app min-h-screen flex flex-col font-sans\">\r\n    <!-- Main Content -->\r\n    <div class=\"main-content flex-1 bg-gradient-to-r from-gray-100 to-blue-50\">\r\n      <router-view />\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, computed } from \"vue\";\r\nimport { useRoute } from \"vue-router\";\r\nexport default {\r\n  data() {\r\n    return {\r\n      isCollapsed: false,\r\n    };\r\n  },\r\n  setup() {\r\n    const route = useRoute();\r\n\r\n    // ✅ Check if user is authenticated\r\n    const isAuthenticated = computed(() => !!localStorage.getItem(\"token\"));\r\n    // Show SideNaviga