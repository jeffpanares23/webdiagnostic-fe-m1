this.page * this.itemsPerPage);\n    },\n    errorCount: function errorCount() {\n      return this.results.pages.filter(function (page) {\n        return page.is_description_missing || !page.is_title_ideal && !page.is_title_too_short || page.hasHttps === \"No\";\n      }).length;\n    },\n    warningCount: function warningCount() {\n      return this.results.pages.filter(function (page) {\n        return page.is_title_too_short || page.is_description_duplicate;\n      }).length;\n    },\n    validCount: function validCount() {\n      return this.results.pages.length - this.errorCount - this.warningCount;\n    }\n  },\n  methods: {\n    sortBy: function sortBy(key) {\n      this.sortOrder = this.sortKey === key ? this.sortOrder === \"asc\" ? \"desc\" : \"asc\" : \"asc\";\n      this.sortKey = key;\n    },\n    nextPage: function nextPage() {\n      this.page++;\n    },\n    prevPage: function prevPage() {\n      this.page--;\n    }\n  }\n};","map":{"version":3,"names":["props","results","type","Object","default","pages","data","searchQuery","filterType","page","itemsPerPage","sortKey","sortOrder","computed","filteredResults","_this","filtered","filter","url","includes","title","is_description_missing","hasHttps","is_title_duplicate","sort","a","b","modifier","slice","errorCount","is_title_ideal","is_title_too_short","length","warningCount","is_description_duplicate","validCount","methods","sortBy","key","nextPage","prevPage"],"sources":["C:\\Users\\RYZEN 5 5500\\Documents\\GitHub\\webdiagnostic-fe-m1\\src\\components\\ValidationResults.vue"],"sourcesContent":["<template>\n  <div class=\"results-container\">\n    <div class=\"scanned-pages\">\n      <h2 class=\"text-lg font-semibold mb-4\">Scanned Pages</h2>\n\n      <!-- Search and Filter -->\n      <div class=\"flex justify-between mb-4\">\n        <input\n          v-model=\"searchQuery\"\n          type=\"text\"\n          placeholder=\"Search URL or Title...\"\n          class=\"border p-2 rounded w-1/3 text-sm\"\n        />\n        <select v-model=\"filterType\" class=\"border p-2 rounded text-sm\">\n          <option value=\"\">All</option>\n          <option value=\"missingDescription\">Missing Description</option>\n          <option value=\"noHttps\">No HTTPS</option>\n          <option value=\"duplicateTitle\">Duplicate Title</option>\n        </select>\n      </div>\n\n      <!-- Table -->\n      <div class=\"overflow-y-auto max-h-[600px] border rounded shadow text-xs\">\n        <table class=\"w-full\">\n          <thead class=\"bg-gray-100 sticky top-0 z-10\">\n            <tr>\n              <th class=\"px-2 py-1\">#</th>\n              <th class=\"px-2 py-1 cursor-pointer\" @click=\"sortBy('url')\">\n                URL\n              </th>\n              <th class=\"px-2 py-1\">Title</th>\n              <th class=\"px-2 py-1\">Title Length</th>\n              <th class=\"px-2 py-1\">Title Status</th>\n              <th class=\"px-2 py-1\">Meta Description</th>\n              <th class=\"px-2 py-1\">Meta Length</th>\n              <th class=\"px-2 py-1\">Meta Status</th>\n              <th class=\"px-2 py-1\">HTTPS</th>\n              <th class=\"px-2 py-1\">Duplicate Title</th>\n              <th class=\"px-2 py-1\">Phone</th>\n              <th class=\"px-2 py-1\">Email</th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr\n              v-for=\"(page, index) in filteredResults\"\n              :key=\"index\"\n              class=\"border-b hover:bg-gray-50\"\n            >\n              <td class=\"px-2 py-1 text-center\">{{ index + 1 }}</td>\n              <td class=\"px-2 py-1 break-words max-w-[200px]\">\n                <a\n                  :href=\"page.url\"\n                  target=\"_blank\"\n                  class=\"text-blue-600 underline\"\n                >\n                  {{ page.url }}\n                </a>\n              </td>\n              <td class=\"px-2 py-1\">{{ page.title }}</td>\n              <td class=\"px-2 py-1 text-center\">{{ page.title_length }}</td>\n              <td class=\"px-2 py-1 text-center\">\n                <span\n                  :class=\"{\n                    'text-green-600': page.is_title_ideal,\n                    'text-yellow-500': page.is_title_too_short,\n                    'text-red-600':\n                      !page.is_title_ideal && !page.is_title_too_short,\n                  }\"\n                >\n                  <span v-if=\"page.is_title_ideal\">Ideal</span>\n                  <span v-else-if=\"page.is_title_too_short\">Too Short</span>\n                  <span v-else>Too Long</span>\n                </span>\n              </td>\n              <td class=\"px-2 py-1\">{{ page.description }}</td>\n              <td class=\"px-2 py-1 text-center\">\n                {{ page.description_length || \"—\" }}\n              </td>\n              <td class=\"px-2 py-1 text-center\">\n                <span\n                  :class=\"{\n                    'text-green-600':\n                      !page.is_description_missing &&\n                      !page.is_description_duplicate,\n                    'text-yellow-500': page.is_description_duplicate,\n                    'text-red-600': page.is_description_missing,\n                  }\"\n                >\n                  <span v-if=\"page.is_description_missing\">Missing</span>\n                  <span v-else-if=\"page.is_description_duplicate\"\n                    >Duplicate</span\n                  >\n                  <span v-else>Valid</span>\n                </span>\n              </td>\n              <td class=\"px-2 py-1 text-center\">\n                <span\n                  :class=\"{\n                    'text-green-600': page.hasHttps === 'Yes',\n                    'text-red-600': page.hasHttps === 'No',\n                  }\"\n                >\n                  {{ page.hasHttps }}\n                </span>\n              </td>\n              <td class=\"px-2 py-1 text-center\">\n                <span\n                  :class=\"\n                    page.is_title_duplicate ? 'text-red-600' : 'text-green-600'\n                  \"\n                >\n                  {{ page.is_title_duplicate ? \"Yes\" : \"No\" }}\n                </span>\n              </td>\n              <td class=\"px-2 py-1\">{{ page.phone }}</td>\n              <td class=\"px-2 py-1\">{{ page.email }}</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      <!-- Summary Bar -->\n      <div\n        class=\"flex justify-between items-center mt-3 px-2 py-1 bg-gray-100 border text-xs\"\n      >\n        <div>Total Pages: {{ results.pages.length }}</div>\n        <div>\n          Errors: {{ errorCount }} | Warnings: {{ warningCount }} | Valid:\n          {{ validCount }}\n        </div>\n      </div>\n\n      <!-- Pagination -->\n      <div class=\"flex justify-between items-center mt-3 text-sm\">\n        <button\n          @click=\"prevPage\"\n          :disabled=\"page === 1\"\n          class=\"px-3 py-1 border rounded\"\n        >\n          Previous\n        </button>\n        <span>Page {{ page }}</span>\n        <button\n          @click=\"nextPage\"\n          :disabled=\"page * itemsPerPage >= results.pages.length\"\n          class=\"px-3 py-1 border rounded\"\n        >\n          Next\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  props: {\n    results: {\n      type: Object,\n      default: () => ({ pages: [] }),\n    },\n  },\n  data() {\n    return {\n      searchQuery: \"\",\n      filterType: \"\",\n      page: 1,\n      itemsPerPage: 10,\n      sortKey: \"url\",\n      sortOrder: \"asc\",\n    };\n  },\n  computed: {\n    filteredResults() {\n      let filtered = this.results.pages;\n\n      if (this.searchQuery) {\n        filtered = filtered.filter(\n          (page) =>\n            page.url.includes(this.searchQuery) ||\n            page.title.includes(this.searchQuery)\n        );\n      }\n\n      if (this.filterType === \"missingDescription\") {\n        filtered = filtered.filter((page) => page.is_description_missing);\n      } else if (this.filterType === \"noHttps\") {\n        filtered = filtered.filter((page) => page.hasHttps === \"No\");\n      } else if (this.filterType === \"duplicateTitle\") {\n        filtered = filtered.filter((page) => page.is_title_duplicate);\n      }\n\n      filtered.sort((a, b) => {\n        let modifier = this.sortOrder === \"asc\" ? 1 : -1;\n        if (a[this.sortKey] < b[this.sortKey]) return -1 * modifier;\n        if (a[this.sortKey] > b[this.sortKey]) return 1 * modifier;\n        return 0;\n      });\n\n      return filtered.slice(\n        (this.page - 1) * this.itemsPerPage,\n        this.page * this.itemsPerPage\n      );\n    },\n\n    errorCount() {\n      return this.results.pages.filter(\n        (page) =>\n          page.is_description_missing ||\n          (!page.is_title_ideal && !page.is_title_too_short) ||\n          page.hasHttps === \"No\"\n      ).length;\n    },\n\n    warningCount() {\n      return this.results.pages.filter(\n        (page) => page.is_title_too_short || page.is_description_duplicate\n      ).length;\n    },\n\n    validCount() {\n      return this.results.pages.length - this.errorCount - this.warningCount;\n    },\n  },\n  methods: {\n    sortBy(key) {\n      this.sortOrder =\n        this.sortKey === key\n          ? this.sortOrder === \"asc\"\n            ? \"desc\"\n            : \"asc\"\n          : \"asc\";\n      this.sortKey = key;\n    },\n    nextPage() {\n      this.page++;\n    },\n    prevPage() {\n      this.page--;\n    },\n  },\n};\n</script>\n\n<style scoped>\nth,\ntd {\n  padding: 4px;\n  text-align: left;\n  white-space: nowrap;\n}\n</style>\n"],"mappings":";;;;;;;;AA4JA,eAAe;EACbA,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZ,WAAS,SAATC,QAAOA,CAAA;QAAA,OAAS;UAAEC,KAAK,EAAE;QAAG,CAAC;MAAA;IAC/B;EACF,CAAC;EACDC,IAAI,