;\n  },\n  mounted: function mounted() {\n    this.fetchHistory();\n  },\n  computed: {\n    filteredIssues: function filteredIssues() {\n      // ✅ Ensure `results` exists and `issues` is an array before filtering\n      if (!this.results || !Array.isArray(this.results.issues)) {\n        return []; // Return an empty array if undefined\n      }\n      return this.results.issues.filter(function (issue) {\n        return issue.type === \"error\";\n      });\n    }\n  },\n  methods: {\n    fetchHistory: function fetchHistory() {\n      var _this = this;\n      return _asyncToGenerator(/*#__PURE__*/_regeneratorRuntime().mark(function _callee() {\n        var token, response, _error$response;\n        return _regeneratorRuntime().wrap(function _callee$(_context) {\n          while (1) switch (_context.prev = _context.next) {\n            case 0:\n              token = localStorage.getItem(\"token\");\n              if (token) {\n                _context.next = 5;\n                break;\n              }\n              _this.errorMessage = \"You are not authenticated. Please log in.\";\n              _this.loading = false;\n              return _context.abrupt(\"return\");\n            case 5:\n              _context.prev = 5;\n              _context.next = 8;\n              return axios.get(\"\".concat(baseUrl, \"/api/diagnostic-history\"), {\n                headers: {\n                  Authorization: \"Bearer \".concat(token)\n                }\n              });\n            case 8:\n              response = _context.sent;\n              _this.history = response.data;\n              _context.next = 15;\n              break;\n            case 12:\n              _context.prev = 12;\n              _context.t0 = _context[\"catch\"](5);\n              console.error(\"Failed to fetch history:\", ((_error$response = _context.t0.response) === null || _error$response === void 0 ? void 0 : _error$response.data) || _context.t0);\n            case 15:\n            case \"end\"