ps: {\n    results: {\n      type: Object,\n      \"default\": function _default() {\n        return {\n          pages: []\n        };\n      }\n    }\n  },\n  data: function data() {\n    return {\n      selectedPage: null,\n      activeTab: \"Meta Data\",\n      tabs: [\"Meta Data\", \"SOP Compliance\"],\n      filters: {\n        titleStatus: \"\",\n        metaStatus: \"\",\n        https: \"\",\n        duplicateTitle: \"\"\n      },\n      searchQuery: \"\",\n      highlight: null,\n      highlightedIssue: null,\n      highlightedIndex: null,\n      passedChecks: 0,\n      totalChecks: 0\n    };\n  },\n  computed: {\n    compliancePercentage: function compliancePercentage() {\n      if (this.totalChecks === 0) return 0;\n      return Math.round(this.passedChecks / this.totalChecks * 100);\n    },\n    // How many SOP fields are valid\n    sopCompliancePassed: function sopCompliancePassed() {\n      if (!this.currentPage.sop) return 0;\n      var count = 0;\n      if (this.currentPage.sop.phone_format_valid) count++;\n      if (this.currentPage.sop.email_format_valid) count++;\n      if (this.currentPage.sop.address_format_valid) count++;\n      if (this.currentPage.sop.company_name_valid) count++;\n      if (this.currentPage.sop.copyright_year_valid) count++;\n      return count;\n    },\n    // Total SOP checks (5 in this example)\n    sopComplianceTotal: function sopComplianceTotal() {\n      return 5;\n    },\n    // Calculate SOP compliance percentage\n    sopCompliancePercentage: function sopCompliancePercentage() {\n      if (this.sopComplianceTotal === 0) return 0;\n      return Math.round(this.sopCompliancePassed / this.sopComplianceTotal * 100);\n    },\n    filteredResults: function filteredResults() {\n      var _this = this;\n      return this.results.pages.filter(function (page) {\n        var matchTitle = _this.filters.titleStatus === \"\" || _this.filters.titleStatus === \"ideal\" && page.is_title_ideal || _this.filters.titleStatus === \"short\" && page.is_title_too_short || _this.filters.titleStatus === \"long\" && !page.is_title_ideal && !page.is_title_too_short;\n        var matchMeta = _this.filters.metaStatus === \"\" || _this.filters.metaStatus === \"missing\" && page.is_description_missing || _this.filters.metaStatus === \"duplicate\" && page.is_description_duplicate || _this.filters.metaStatus === \"valid\" && !page.is_description_missing && !page.is_description_duplicate;\n        var matchHttps = _this.filters.https === \"\" || page.hasHttps === _this.filters.https;\n        var matchDupTitle = _this.filters.duplicateTitle === \"\" || _this.filters.duplicateTitle === \"Yes\" && page.is_title_duplicate || _this.filters.duplicateTitle === \"No\" && !page.is_title_duplicate;\n        var matchSearch = page.url.toLowerCase().includes(_this.searchQuery.toLowerCase());\n        return matchTitle && matchMeta && matchHttps && matchDupTitle && matchSearch;\n      });\n    },\n    filteredIssuesToFix: function filteredIssuesToFix() {\n      var _this2 = this;\n      if (!this.currentPage || !this.currentPage.issues) return [];\n      return this.currentPage.issues.filter(function (issue) {\n        if (_this2.activeTab === \"Meta Data\") {\n          return issue.section === \"metadata\" && !issue.message.toLowerCase().includes(\"https\");\n        } else if (_this2.activeTab === \"SOP Compliance\") {\n          return issue.section === \"sop\" || issue.message.toLowerCase().includes(\"https\");\n        }\n        return false;\n      });\n    },\n    // currentPage() {\n    //   return this.selectedPage !== null\n    //     ? this.filteredResults[this.selectedPage]\n    //     : {};\n    // },\n    currentPage: function currentPage() {\n      return this.selectedPage !== null ? this.results.pages[this.selectedPage] : {};\n    },\n    chartData: function chartData() {\n      var errors = this.results.pages.filter(function (p) {\n        return p.is_description_missing || !p.is_title_ideal && !p.is_title_too_short || p.hasHttps === \"No\";\n      }).length;\n      var warnings = this.results.pages.filter(function (p) {\n        return p.is_title_too_short || p.is_description_duplicate;\n      }).length;\n      var valid = this.results.pages.length - errors - warnings;\n      return {\n        labels: [\"Valid\", \"Warnings\", \"Errors\"],\n        datasets: [{\n          data: [valid, warnings, errors],\n          backgroundColor: [\"#22c55e\", \"#facc15\", \"#ef4444\"]\n        }]\n      };\n    },\n    hasIssues: function hasIssues() {\n      // return this.currentPage.issues && this.currentPage.issues.length > 0;\n      return this.filteredIssuesToFix.length > 0;\n    },\n    allIssues: function allIssues() {\n      if (!this.results.pages) return [];\n      return this.results.pages.flatMap(function (page) {\n        return page.issues || [];\n      });\n    },\n    // metadataIssues() {\n    //   console.log(this.results.issues);\n    //   return this.results.issues?.filter((i) => i.section === \"metadata\") || [];\n    // },\n    // sopIssues() {\n    //   return this.results.issues?.filter((i) => i.section === \"sop\") || [];\n    // },\n    metadataIssues: function metadataIssues() {\n      if (!this.currentPage || !this.currentPage.issues) return [];\n      return this.currentPage.issues.filter(function (i) {\n        return i.section === \"metadata\";\n      });\n    },\n    sopIssues: function sopIssues() {\n      if (!this.currentPage || !this.currentPage.issues) return [];\n      return this.currentPage.issues.filter(function (i) {\n        return i.section === \"sop\";\n      });\n    }\n  },\n  methods: {\n    // selectPage(index) {\n    //   this.selectedPage = index;\n    //   localStorage.setItem(\"selectedPageIndex\", index);\n    // },\n    getExplanation: function getExplanation(issue) {\n      return issue.explanation || \"\";\n    },\n    selectPage: function selectPage(index) {\n      var page = this.filteredResults[index];\n      if (!page) {\n        console.warn(\"Selected page not found in filteredResults.\");\n        return;\n      }\n      var originalIndex = this.results.pages.findIndex(function (p) {\n        return p.url === page.url;\n      });\n      if (originalIndex !== -1) {\n        this.selectedPage = originalIndex;\n        localStorage.setItem(\"selectedPageIndex\", originalIndex);\n      } else {\n        console.warn(\"Page not found in original results.pages.\");\n      }\n    },\n    exportToCSV: function exportToCSV() {\n      var rows = this.filteredResults.map(function (page) {\n        var _page$sop, _page$sop2, _page$sop3, _page$sop4, _page$sop5;\n        return {\n          URL: page.url,\n          Title: page.title,\n          MetaDescription: page.description,\n          HTTPS: page.hasHttps,\n          DuplicateTitle: page.is_title_duplicate ? \"Yes\" : \"No\",\n          Phone: page.phone,\n          Email: page.email,\n          company_name: page.company_name,\n          PhoneFormatValid: (_page$sop = page.sop) !== null && _page$sop !== void 0 && _page$sop.phone_format_valid ? \"Yes\" : \"No\",\n          EmailFormatValid: (_page$sop2 = page.sop) !== null && _page$sop2 !== void 0 && _page$sop2.email_format_valid ? \"Yes\" : \"No\",\n          AddressFormatValid: (_page$sop3 = page.sop) !== null && _page$sop3 !== void 0 && _page$sop3.address_format_valid ? \"Yes\" : \"No\",\n          CompanyNameValid: (_page$sop4 = page.sop) !== null && _page$sop4 !== void 0 && _page$sop4.company_name_valid ? \"Yes\" : \"No\",\n          CopyrightValid: (_page$sop5 = page.sop) !== null && _page$sop5 !== void 0 && _page$sop5.copyright_year_valid ? \"Yes\" : \"No\"\n        };\n      });\n      var csv = [Object.keys(rows[0]).join(\",\")].concat(_toConsumableArray(rows.map(function (row) {\n        return Object.values(row).map(function (val) {\n          return \"\\\"\".concat(val, \"\\\"\");\n        }).join(\",\");\n      }))).join(\"\\n\");\n      var blob = new Blob([csv], {\n        type: \"text/csv\"\n      });\n      var url = URL.createObjectURL(blob);\n      var link = document.createElement(\"a\");\n      link.href = url;\n      link.download = \"validation_results.csv\";\n      link.click();\n      URL.revokeObjectURL(url);\n    }\n  },\n  mounted: function mounted() {\n    var savedIndex = localStorage.getItem(\"selectedPageIndex\");\n    if (savedIndex) {\n      this.selectedPage = parseInt(savedIndex);\n    }\n  }\n};","map":{"version":3,"names":["Chart","ChartJS","Title","Tooltip","Legend","ArcElement","PieChart","PageIssuesPanel","register","name","components","props","results","type","Object","default","pages","data","selectedPage","activeTab","tabs","filters","titleStatus","metaStatus","https","duplicateTitle","searchQuery","highlight","highlightedIssue","highlightedIndex","passedChecks","totalChecks","computed","compliancePercentage","Math","round","sopCompliancePassed","currentPage","sop","count","phone_format_valid","email_format_valid","address_format_valid","company_name_valid","copyright_year_valid","sopComplianceTotal","sopCompliancePercentage","filteredResults","_this","filter","page","matchTitle","is_title_ideal","is_title_too_short","matchMeta","is_description_missing","is_description_duplicate","matchHttps","hasHttps","matchDupTitle","is_title_duplicate","matchSearch","url","toLowerCase","includes","filteredIssuesToFix","_this2","issues","issue","section","message","chartData","errors","p","length","warnings","valid","labels","datasets","backgroundColor","hasIssues","allIssues","flatMap","metadataIssues","i","sopIssues","methods","getExplanation","explanation","selectPage","index","console","warn","originalIndex","findIndex","localStorage","setItem","exportToCSV","rows","map","_page$sop","_page$sop2","_page$sop3","_page$sop4","_page$sop5","URL","title","MetaDescription","description","HTTPS","DuplicateTitle","Phone","phone","Email","email","company_name","PhoneFormatValid","EmailFormatValid","AddressFormatValid","CompanyNameValid","CopyrightValid","csv","keys","join","concat","_toConsumableArray","row","values","val","blob","Blob","createObjectURL","link","document","createElement","href","download","click","revokeObjectURL","mounted","savedIndex","getItem","parseInt"],"sources":["C:\\Users\\Production\\Documents\\GitHub\\OUTSOURCE\\WDTool\\webdiagnostic-fe-m1\\src\\components\\ValidationResults.vue"],"sourcesContent":["<template>\r\n  <div class=\"grid grid-cols-12 gap-4\">\r\n    <!-- Left: Main Results Table -->\r\n    <div class=\"col-span-9\">\r\n      <div class=\"mb-4 flex justify-between items-center\">\r\n        <h2 class=\"text-lg font-semibold\">Scanned Pages</h2>\r\n        <button\r\n          @click=\"exportToCSV\"\r\n          class=\"bg-blue-600 text-white px-4 py-1 rounded text-sm hover:bg-blue-700\"\r\n        >\r\n          Export CSV\r\n        </button>\r\n      </div>\r\n\r\n      <!-- Per-column Filters -->\r\n      <div class=\"grid grid-cols-6 gap-2 mb-2 text-xs\">\r\n        <select v-model=\"filters.titleStatus\" class=\"border p-1 rounded\">\r\n          <option value=\"\">All Titles</option>\r\n          <option value=\"ideal\">Ideal</option>\r\n          <option value=\"short\">Too Short</option>\r\n          <option value=\"long\">Too Long</option>\r\n        </select>\r\n        <select v-model=\"filters.metaStatus\" class=\"border p-1 rounded\">\r\n          <option value=\"\">All Meta</option>\r\n          <option value=\"valid\">Valid</option>\r\n          <option value=\"missing\">Missing</option>\r\n          <option value=\"duplicate\">Duplicate</option>\r\n        </select>\r\n        <select v-model=\"filters.https\" class=\"border p-1 rounded\">\r\n          <option value=\"\">All HTTPS</option>\r\n          <option value=\"Yes\">HTTPS</option>\r\n          <option value=\"No\">HTTP</option>\r\n        </select>\r\n        <select v-model=\"filters.duplicateTitle\" class=\"border p-1 rounded\">\r\n          <option value=\"\">Duplicate Title?</option>\r\n          <option value=\"Yes\">Yes</option>\r\n          <option value=\"No\">No</option>\r\n        </select>\r\n        <input\r\n          v-model=\"searchQuery\"\r\n          type=\"text\"\r\n          placeholder=\"Search URL...\"\r\n          class=\"border p-1 rounded col-span-2\"\r\n        />\r\n      </div>\r\n\r\n      <!-- Results Table -->\r\n      <div class=\"overflow-y-auto max-h-[420px] border rounded text-xs\">\r\n        <table class=\"w-full\">\r\n          <thead class=\"bg-gray-100 sticky top-0 z-10\">\r\n            <tr>\r\n              <th class=\"px-2 py-1\">#</th>\r\n              <th class=\"px-2 py-1\">URL</th>\r\n              <th class=\"px-2 py-1\">Title</th>\r\n              <th class=\"px-2 py-1\">Meta Desc</th>\r\n              <th class=\"px-2 py-1\">HTTPS</th>\r\n              <th class=\"px-2 py-1\">Status</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr\r\n              v-for=\"(page, index) in filteredResults\"\r\n              :key=\"index\"\r\n              class=\"hover:bg-blue-50 border-b cursor-pointer\"\r\n              @click=\"selectPage(index)\"\r\n            >\r\n              <td class=\"px-2 py-1 text-center\">{{ index + 1 }}</td>\r\n              <td class=\"px-2 py-1 text-blue-600 underline break-all\">\r\n                {{ page.url }}\r\n              </td>\r\n              <td class=\"px-2 py-1\">{{ page.title }}</td>\r\n              <td class=\"px-2 py-1\">{{ page.description || \"—\" }}</td>\r\n              <td class=\"px-2 py-1\">{{ page.hasHttps }}</td>\r\n              <td class=\"px-2 py-1\">\r\n                <span\r\n                  v-if=\"page.is_description_missing || !page.is_title_ideal\"\r\n                  class=\"text-red-600\"\r\n                  >❌ Issues</span\r\n                >\r\n                <span\r\n                  v-else-if=\"\r\n                    page.is_title_too_short || page.is_description_duplicate\r\n                  \"\r\n                  class=\"text-yellow-500\"\r\n                  >⚠️ Warnings</span\r\n                >\r\n                <span v-else class=\"text-green-600\">✅ Valid</span>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n\r\n      <!-- Bottom Panel: Tabbed Page Details -->\r\n      <div\r\n        v-if=\"selectedPage !== null\"\r\n        class=\"mt-4 border rounded p-3 bg-gray-50\"\r\n      >\r\n        <div class=\"mb-2\">\r\n          <h3 class=\"font-semibold text-sm\">\r\n            Details for:\r\n            <span class=\"text-blue-600\">{{ currentPage.url }}</span>\r\n          </h3>\r\n        </div>\r\n        <div class=\"flex text-sm\">\r\n          <button\r\n            v-for=\"tab in tabs\"\r\n            :key=\"tab\"\r\n            @click=\"activeTab = tab\"\r\n            :class=\"[\r\n              'px-3 py-1 rounded-t-md',\r\n              activeTab === tab\r\n                ? 'bg-white border-t border-l border-r'\r\n                : 'hover:bg-gray-300',\r\n            ]\"\r\n          >\r\n            {{ tab }}\r\n          </button>\r\n        </div>\r\n\r\n        <!-- Tab Content -->\r\n        <div class=\"text-sm\">\r\n          <div v-if=\"activeTab === 'Meta Data'\">\r\n            <div class=\"metadata bg-gray-50 p-4 rounded-md border\">\r\n              <h3 class=\"text-md font-semibold mb-2\">Metadata Validation</h3>\r\n\r\n              <!-- Meta Title Validation -->\r\n              <div class=\"p-3 border-b bg-white shadow-md rounded-md mb-2\">\r\n                <p class=\"font-bold\">Meta Title Test</p>\r\n                <p>\r\n                  <strong>Text: </strong>\r\n                  <span v-if=\"currentPage.title\">{{ currentPage.title }}</span>\r\n                  <span v-else class=\"text-gray-400\">No Meta Title Found</span>\r\n                </p>\r\n                <p>\r\n                  <strong>Length: </strong>\r\n                  <span v-if=\"currentPage.title_length\">\r\n                    {{ currentPage.title_length }} characters\r\n                  </span>\r\n                  <span v-else class=\"text-gray-400\">No Data</span>\r\n                </p>\r\n                <p v-if=\"!currentPage.title\" class=\"text-red-500 font-bold\">\r\n                  ⚠️ No Meta Title detected. Ensure your page has a proper title\r\n                  for better SEO.\r\n                </p>\r\n                <p\r\n                  v-if=\"currentPage.is_title_duplicate\"\r\n                  class=\"text-red-500 font-bold\"\r\n                >\r\n                  ⚠️ Duplicate Page Title Found\r\n                </p>\r\n                <p\r\n                  v-if=\"\r\n                    currentPage.title_length < 50 &&\r\n                    currentPage.title_length > 0\r\n                  \"\r\n                  class=\"text-yellow-500 font-bold\"\r\n                >\r\n                  ⚠️ Title is Too Short\r\n                </p>\r\n                <p\r\n                  v-if=\"currentPage.title_length > 60\"\r\n                  class=\"text-yellow-500 font-bold\"\r\n                >\r\n                  ⚠️ Title is Too Long\r\n                </p>\r\n                <p\r\n                  v-if=\"\r\n                    currentPage.title_length >= 50 &&\r\n                    currentPage.title_length <= 60\r\n                  \"\r\n                  class=\"text-green-500 font-bold\"\r\n                >\r\n                  ✅ Title is in the Ideal Range\r\n                </p>\r\n              </div>\r\n\r\n              <!-- Meta Description Validation -->\r\n              <div class=\"p-3 border-b bg-white shadow-md rounded-md\">\r\n                <p class=\"font-bold\">Meta Description Test</p>\r\n                <p>\r\n                  <strong>Text: </strong>\r\n                  <span v-if=\"currentPage.description\">\r\n                    {{ currentPage.description }}\r\n                  </span>\r\n                  <span v-else class=\"text-gray-400\"\r\n                    >No Meta Description Found</span\r\n                  >\r\n                </p>\r\n                <p>\r\n                  <strong>Length: </strong>\r\n                  <span v-if=\"currentPage.description_length\">\r\n                    {{ currentPage.description_length }} characters\r\n                  </span>\r\n                  <span v-else class=\"text-gray-400\">No Data</span>\r\n                </p>\r\n                <p\r\n                  v-if=\"!currentPage.description\"\r\n                  class=\"text-red-500 font-bold\"\r\n                >\r\n                  ⚠️ No Meta Description detected. Add a brief summary of your\r\n                  page for better SEO.\r\n                </p>\r\n                <p\r\n                  v-if=\"\r\n                    currentPage.description_length < 150 &&\r\n                    currentPage.description_length > 0\r\n                  \"\r\n                  class=\"text-yellow-500 font-bold\"\r\n                >\r\n                  ⚠️ Meta Description is Too Short\r\n                </p>\r\n                <p\r\n                  v-if=\"currentPage.description_length > 220\"\r\n                  class=\"text-yellow-500 font-bold\"\r\n                >\r\n                  ⚠️ Meta Description is Too Long\r\n                </p>\r\n                <p\r\n                  v-if=\"\r\n                    currentPage.description_length >= 150 &&\r\n                    currentPage.description_length <= 220\r\n                  \"\r\n                  class=\"text-green-500 font-bold\"\r\n                >\r\n                  ✅ Meta Description is in the Ideal Range\r\n                </p>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Optional: still keep the issues panel below -->\r\n          </div>\r\n\r\n          <div v-else-if=\"activeTab === 'SOP Compliance'\">\r\n            <!-- 1. Quick Summary: SOP Compliance Overview -->\r\n            <div class=\"p-4 mb-4 bg-gray-50 border rounded-md\">\r\n              <h3 class=\"font-semibold text-sm text-gray-700 mb-2\">\r\n                SOP Compliance Overview\r\n              </h3>\r\n              <p class=\"text-xs text-gray-500\">\r\n                Below is a quick summary of your compliance status. Items in\r\n                <span class=\"text-red-500\">red</span> need attention.\r\n              </p>\r\n\r\n              <!-- Progress Bar -->\r\n              <div class=\"mt-2 bg-gray-200 h-2 w-full rounded-full\">\r\n                <div\r\n                  class=\"bg-green-500 h-2 rounded-full\"\r\n                  :style=\"{ width: sopCompliancePercentage + '%' }\"\r\n                ></div>\r\n              </div>\r\n              <p class=\"mt-1 text-xs text-gray-700\">\r\n                {{ sopCompliancePassed }}/{{ sopComplianceTotal }} checks passed\r\n                ({{ sopCompliancePercentage }}%)\r\n              </p>\r\n            </div>\r\n\r\n            <!-- 2. Grouped Sections -->\r\n            <div class=\"space-y-4\">\r\n              <!-- Contact Info -->\r\n              <div class=\"p-4 bg-white border rounded-md shadow-sm\">\r\n                <h4 class=\"text-md font-semibold mb-3\">Contact Info</h4>\r\n                <div class=\"grid grid-cols-2 gap-4 text-sm\">\r\n                  <!-- Phone Number -->\r\n                  <div>\r\n                    <strong>Phone Number: &nbsp;</strong>\r\n                    <span\r\n                      :class=\"{\r\n                        'text-green-600': currentPage.sop?.phone_format_valid,\r\n                        'text-red-500':\r\n                          currentPage.sop?.phone_format_valid === false,\r\n                      }\"\r\n                    >\r\n                      {{ currentPage.phone || \"—\" }}\r\n                    </span>\r\n                  </div>\r\n\r\n                  <!-- Email Address -->\r\n                  <div>\r\n                    <strong>Email Address: &nbsp;</strong>\r\n                    <span\r\n                      :class=\"{\r\n                        'text-green-600': currentPage.sop?.email_format_valid,\r\n                        'text-red-500':\r\n                          currentPage.sop?.email_format_valid === false,\r\n                      }\"\r\n                    >\r\n                      {{ currentPage.email || \"—\" }}\r\n                    </span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <!-- Company Info -->\r\n              <div class=\"p-4 bg-white border rounded-md shadow-sm\">\r\n                <h4 class=\"text-md font-semibold mb-3\">Company Info</h4>\r\n                <div class=\"grid grid-cols-2 gap-4 text-sm\">\r\n                  <!-- Company Name -->\r\n                  <div>\r\n                    <strong>Company Name: &nbsp;</strong>\r\n                    <span\r\n                      :class=\"{\r\n                        'text-green-600': currentPage.sop?.company_name_valid,\r\n                        'text-red-500':\r\n                          currentPage.sop?.company_name_valid === false,\r\n                      }\"\r\n                    >\r\n                      {{ currentPage.company_name || \"—\" }}\r\n                    </span>\r\n                  </div>\r\n\r\n                  <!-- Address -->\r\n                  <div>\r\n                    <strong>Address: &nbsp;</strong>\r\n                    <span\r\n                      :class=\"{\r\n                        'text-green-600': currentPage.sop?.address_format_valid,\r\n                        'text-red-500':\r\n                          currentPage.sop?.address_format_valid === false,\r\n                      }\"\r\n                    >\r\n                      {{ currentPage.address || \"—\" }}\r\n                    </span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              <!-- Legal -->\r\n              <div class=\"p-4 bg-white border rounded-md shadow-sm\">\r\n                <h4 class=\"text-md font-semibold mb-3\">Legal</h4>\r\n                <div class=\"grid grid-cols-2 gap-4 text-sm\">\r\n                  <!-- Removed Privacy Policy -->\r\n                  <div>\r\n                    <strong>Copyright: &nbsp;</strong>\r\n                    <span\r\n                      :class=\"{\r\n                        'text-green-600': currentPage.sop?.copyright_year_valid,\r\n                        'text-red-500':\r\n                          currentPage.sop?.copyright_year_valid === false,\r\n                      }\"\r\n                    >\r\n                      {{ currentPage.copyright || \"—\" }}\r\n                    </span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Right: Chart Sidebar -->\r\n    <div class=\"col-span-3 bg-white border rounded p-3 text-sm\">\r\n      <h3 class=\"font-semibold mb-2\">Validation Summary</h3>\r\n      <PieChart :chart-data=\"chartData\" />\r\n    </div>\r\n    <!-- Issues to Fix Section -->\r\n    <div class=\"col-span-12 mt-4\">\r\n      <div class=\"issues-to-fix bg-white p-4 rounded-md border\">\r\n        <h3 class=\"text-md font-semibold mb-2\">🚨 Issues to Fix</h3>\r\n        <div v-if=\"hasIssues\" class=\"space-y-3\">\r\n          <div\r\n            v-for=\"(issue, index) in filteredIssuesToFix\"\r\n            :key=\"index\"\r\n            class=\"flex items-center p-3 border-l-4 rounded-md shadow-sm transition-all duration-200 hover:shadow-lg cursor-pointer\"\r\n            :class=\"{\r\n              'bg-red-50 border-red-500': issue.priority === 'HIGH',\r\n              'bg-yellow-50 border-yellow-500': issue.priority === 'MEDIUM',\r\n              'bg-green-50 border-green-500': issue.priority === 'LOW',\r\n            }\"\r\n            @click=\"scrollToSection(issue.section)\"\r\n          >\r\n            <span\r\n              class=\"text-xs font-bold px-3 py-1 min-w-20 text-center rounded\"\r\n              :class=\"{\r\n                'bg-red-500 text-white': issue.priority === 'HIGH',\r\n                'bg-yellow-500 text-white': issue.priority === 'MEDIUM',\r\n                'bg-green-500 text-white': issue.priority === 'LOW',\r\n              }\"\r\n            >\r\n              {{ issue.priority }}\r\n            </span>\r\n\r\n            <p class=\"ml-4 text-gray-700 flex items-center\">\r\n              <a class=\"hover:text-blue-700\">\r\n                {{ issue.message }}\r\n              </a>\r\n            </p>\r\n          </div>\r\n        </div>\r\n        <p v-else class=\"text-gray-500\">✅ No critical issues found.</p>\r\n      </div>\r\n\r\n      <!-- Metadata Issues -->\r\n      <div\r\n        v-if=\"activeTab === 'Meta Data'\"\r\n        ref=\"metadataIssues\"\r\n        class=\"metadata-issues bg-white p-4 rounded-md border mt-4\"\r\n        :class=\"{ 'highlight-section': highlight === 'metadata' }\"\r\n      >\r\n        <h3 class=\"text-md font-semibold mb-2\">📄 Metadata Issues</h3>\r\n        <PageIssuesPanel\r\n          :issues=\"currentPage.issues || []\"\r\n          section=\"metadata\"\r\n        />\r\n      </div>\r\n\r\n      <!-- SOP Compliance Issues -->\r\n      <div\r\n        v-if=\"activeTab === 'SOP Compliance'\"\r\n        ref=\"sopIssues\"\r\n        class=\"sop-issues bg-white p-4 rounded-md border mt-4\"\r\n        :class=\"{ 'highlight-section': highlight === 'sop' }\"\r\n      >\r\n        <h3 class=\"text-sm font-semibold mb-2\">🏢 SOP Compliance Issues</h3>\r\n        <!-- <div v-if=\"sopIssues.length > 0\" class=\"space-y-3\">\r\n          <div\r\n            v-for=\"(issue, index) in sopIssues\"\r\n            :key=\"index\"\r\n            ref=\"sopIssueRefs\"\r\n            class=\"p-4 border rounded-md shadow-sm transition-all duration-300\"\r\n            :class=\"{\r\n              'border-red-500 bg-red-50': issue.priority === 'HIGH',\r\n              'border-yellow-500 bg-yellow-50': issue.priority === 'MEDIUM',\r\n              'border-green-500 bg-green-50': issue.priority === 'LOW',\r\n              highlighted:\r\n                highlightedIssue === 'sop' && highlightedIndex === index,\r\n            }\"\r\n          >\r\n            <div class=\"flex items-center mb-2\">\r\n              <span class=\"text-lg mr-2\">\r\n                <i\r\n                  v-if=\"issue.priority === 'HIGH'\"\r\n                  class=\"fa-solid fa-radiation text-red-800\"\r\n                ></i>\r\n                <i\r\n                  v-if=\"issue.priority === 'MEDIUM'\"\r\n                  class=\"fa-solid fa-triangle-exclamation text-yellow-500\"\r\n                ></i>\r\n                <i\r\n                  v-if=\"issue.priority === 'LOW'\"\r\n                  class=\"fa-solid fa-triangle-exclamation text-green-500\"\r\n                ></i>\r\n              </span>\r\n              <h4 class=\"text-md font-semibold\">{{ issue.message }}</h4>\r\n            </div>\r\n            <p class=\"text-gray-700 text-sm\">\r\n              <strong>Why this matters:</strong>\r\n              {{ getExplanation(issue) || \"No explanation provided.\" }}\r\n            </p>\r\n            <a\r\n              :href=\"issue.link\"\r\n              target=\"_blank\"\r\n              class=\"text-blue-500 underline mt-2 inline-block\"\r\n            >\r\n              Learn More\r\n            </a>\r\n          </div>\r\n        </div> -->\r\n        <PageIssuesPanel :issues=\"currentPage.issues || []\" section=\"sop\" />\r\n        <!-- <PageIssuesPanel :issues=\"currentPage.issues || []\" section=\"sop\" /> -->\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nimport { Chart as ChartJS, Title, Tooltip, Legend, ArcElement } from \"chart.js\";\r\nimport PieChart from \"@/components/PieChart.vue\";\r\nimport PageIssuesPanel from \"@/components/validation/PageIssuesPanel.vue\";\r\n\r\nChartJS.register(Title, Tooltip, Legend, ArcElement);\r\nexport default {\r\n  name: \"ValidationResults\",\r\n  components: { PieChart, PageIssuesPanel },\r\n  props: {\r\n    results: {\r\n      type: Object,\r\n      default: () => ({ pages: [] }),\r\n    },\r\n  },\r\n  data() {\r\n    return {\r\n      selectedPage: null,\r\n      activeTab: \"Meta Data\",\r\n      tabs: [\"Meta Data\", \"SOP Compliance\"],\r\n      filters: {\r\n        titleStatus: \"\",\r\n        metaStatus: \"\",\r\n        https: \"\",\r\n        duplicateTitle: \"\",\r\n      },\r\n      searchQuery: \"\",\r\n      highlight: null,\r\n      highlightedIssue: null,\r\n      highlightedIndex: null,\r\n      passedChecks: 0,\r\n      totalChecks: 0,\r\n    };\r\n  },\r\n  computed: {\r\n    compliancePercentage() {\r\n      if (this.totalChecks === 0) return 0;\r\n      return Math.round((this.passedChecks / this.totalChecks) * 100);\r\n    },\r\n    // How many SOP fields are valid\r\n    sopCompliancePassed() {\r\n      if (!this.currentPage.sop) return 0;\r\n      let count = 0;\r\n      if (this.currentPage.sop.phone_format_valid) count++;\r\n      if (this.currentPage.sop.email_format_valid) count++;\r\n      if (this.currentPage.sop.address_format_valid) count++;\r\n      if (this.currentPage.sop.company_name_valid) count++;\r\n      if (this.currentPage.sop.copyright_year_valid) count++;\r\n      return count;\r\n    },\r\n    // Total SOP checks (5 in this example)\r\n    sopComplianceTotal() {\r\n      return 5;\r\n    },\r\n    // Calculate SOP compliance percentage\r\n    sopCompliancePercentage() {\r\n      if (this.sopComplianceTotal === 0) return 0;\r\n      return Math.round(\r\n        (this.sopCompliancePassed / this.sopComplianceTotal) * 100\r\n      );\r\n    },\r\n    filteredResults() {\r\n      return this.results.pages.filter((page) => {\r\n        const matchTitle =\r\n          this.filters.titleStatus === \"\" ||\r\n          (this.filters.titleStatus === \"ideal\" && page.is_title_ideal) ||\r\n          (this.filters.titleStatus === \"short\" && page.is_title_too_short) ||\r\n          (this.filters.titleStatus === \"long\" &&\r\n            !page.is_title_ideal &&\r\n            !page.is_title_too_short);\r\n\r\n        const matchMeta =\r\n          this.filters.metaStatus === \"\" ||\r\n          (this.filters.metaStatus === \"missing\" &&\r\n            page.is_description_missing) ||\r\n          (this.filters.metaStatus === \"duplicate\" &&\r\n            page.is_description_duplicate) ||\r\n          (this.filters.metaStatus === \"valid\" &&\r\n            !page.is_description_missing &&\r\n            !page.is_description_duplicate);\r\n\r\n        const matchHttps =\r\n          this.filters.https === \"\" || page.hasHttps === this.filters.https;\r\n        const matchDupTitle =\r\n          this.filters.duplicateTitle === \"\" ||\r\n          (this.filters.duplicateTitle === \"Yes\" && page.is_title_duplicate) ||\r\n          (this.filters.duplicateTitle === \"No\" && !page.is_title_duplicate);\r\n\r\n        const matchSearch = page.url\r\n          .toLowerCase()\r\n          .includes(this.searchQuery.toLowerCase());\r\n\r\n        return (\r\n          matchTitle && matchMeta && matchHttps && matchDupTitle && matchSearch\r\n        );\r\n      });\r\n    },\r\n    filteredIssuesToFix() {\r\n      if (!this.currentPage || !this.currentPage.issues) return [];\r\n\r\n      return this.currentPage.issues.filter((issue) => {\r\n        if (this.activeTab === \"Meta Data\") {\r\n          return (\r\n            issue.section === \"metadata\" &&\r\n            !issue.message.toLowerCase().includes(\"https\")\r\n          );\r\n        } else if (this.activeTab === \"SOP Compliance\") {\r\n          return (\r\n            issue.section === \"sop\" ||\r\n            issue.message.toLowerCase().includes(\"https\")\r\n          );\r\n        }\r\n        return false;\r\n      });\r\n    },\r\n    // currentPage() {\r\n    //   return this.selectedPage !== null\r\n    //     ? this.filteredResults[this.selectedPage]\r\n    //     : {};\r\n    // },\r\n    currentPage() {\r\n      return this.selectedPage !== null\r\n        ? this.results.pages[this.selectedPage]\r\n        : {};\r\n    },\r\n\r\n    chartData() {\r\n      const errors = this.results.pages.filter(\r\n        (p) =>\r\n          p.is_description_missing ||\r\n          (!p.is_title_ideal && !p.is_title_too_short) ||\r\n          p.hasHttps === \"No\"\r\n      ).length;\r\n\r\n      const warnings = this.results.pages.filter(\r\n        (p) => p.is_title_too_short || p.is_description_duplicate\r\n      ).length;\r\n\r\n      const valid = this.results.pages.length - errors - warnings;\r\n\r\n      return {\r\n        labels: [\"Valid\", \"Warnings\", \"Errors\"],\r\n        datasets: [\r\n          {\r\n            data: [valid, warnings, errors],\r\n            backgroundColor: [\"#22c55e\", \"#facc15\", \"#ef4444\"],\r\n          },\r\n        ],\r\n      };\r\n    },\r\n    hasIssues() {\r\n      // return this.currentPage.issues && this.currentPage.issues.length > 0;\r\n      return this.filteredIssuesToFix.length > 0;\r\n    },\r\n    allIssues() {\r\n      if (!this.results.pages) return [];\r\n      return this.results.pages.flatMap((page) => page.issues || []);\r\n    },\r\n    // metadataIssues() {\r\n    //   console.log(this.results.issues);\r\n\r\n    //   return this.results.issues?.filter((i) => i.section === \"metadata\") || [];\r\n    // },\r\n    // sopIssues() {\r\n    //   return this.results.issues?.filter((i) => i.section === \"sop\") || [];\r\n    // },\r\n    metadataIssues() {\r\n      if (!this.currentPage || !this.currentPage.issues) return [];\r\n      return this.currentPage.issues.filter((i) => i.section === \"metadata\");\r