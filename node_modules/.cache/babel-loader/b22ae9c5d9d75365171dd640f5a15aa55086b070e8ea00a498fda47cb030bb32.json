{val}\"`)\r\n            .join(\",\")\r\n        ),\r\n      ].join(\"\\n\");\r\n\r\n      const blob = new Blob([csv], { type: \"text/csv\" });\r\n      const url = URL.createObjectURL(blob);\r\n      const link = document.createElement(\"a\");\r\n      link.href = url;\r\n      link.download = \"validation_results.csv\";\r\n      link.click();\r\n      URL.revokeObjectURL(url);\r\n    },\r\n  },\r\n  mounted() {\r\n    const savedIndex = localStorage.getItem(\"selectedPageIndex\");\r\n    if (savedIndex) {\r\n      this.selectedPage = parseInt(savedIndex);\r\n    }\r\n  },\r\n};\r\n</script>\r\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;AAmdA,SAASA,KAAI,IAAKC,OAAO,EAAEC,KAAK,EAAEC,OAAO,EAAEC,MAAM,EAAEC,UAAS,QAAS,UAAU;AAC/E,OAAOC,QAAO,MAAO,2BAA2B;AAChD,OAAOC,eAAc,MAAO,6CAA6C;AAEzEN,OAAO,CAACO,QAAQ,CAACN,KAAK,EAAEC,OAAO,EAAEC,MAAM,EAAEC,UAAU,CAAC;AACpD,eAAe;EACbI,IAAI,EAAE,mBAAmB;EACzBC,UAAU,EAAE;IAAEJ,QAAQ,EAARA,QAAQ;IAAEC,eAAc,EAAdA;EAAgB,CAAC;EACzCI,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZ,WAAS,SAATC,QAAOA,CAAA;QAAA,OAAS;UAAEC,KAAK,EAAE;QAAG,CAAC;MAAA;IAC/B;EACF,CAAC;EACDC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE,IAAI;MAClBC,SAAS,EAAE,WAAW;MACtBC,IAAI,EAAE,CAAC,WAAW,EAAE,gBAAgB,CAAC;MACrCC,OAAO,EAAE;QACPC,WAAW,EAAE,EAAE;QACfC,UAAU,EAAE,EAAE;QACdC,KAAK,EAAE,EAAE;QACTC,cAAc,EAAE;MAClB,CAAC;MACDC,WAAW,EAAE,EAAE;MACfC,SAAS,EAAE,IAAI;MACfC,gBAAgB,EAAE,IAAI;MACtBC,gBAAgB,EAAE,IAAI;MACtBC,YAAY,EAAE,CAAC;MACfC,WAAW,EAAE;IACf,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,oBAAoB,WAApBA,oBAAoBA,CAAA,EAAG;MACrB,IAAI,IAAI,CAACF,WAAU,KAAM,CAAC,EAAE,OAAO,CAAC;MACpC,OAAOG,IAAI,CAACC,KAAK,CAAE,IAAI,CAACL,YAAW,GAAI,IAAI,CAACC,WAAW,GAAI,GAAG,CAAC;IACjE,CAAC;IACD;IACAK,mBAAmB,WAAnBA,mBAAmBA,CAAA,EAAG;MACpB,IAAI,CAAC,IAAI,CAACC,WAAW,CAACC,GAAG,EAAE,OAAO,CAAC;MACnC,IAAIC,KAAI,GAAI,CAAC;MACb,IAAI,IAAI,CAACF,WAAW,CAACC,GAAG,CAACE,kBAAkB,EAAED,KAAK,EAAE;MACpD,IAAI,IAAI,CAACF,WAAW,CAACC,GAAG,CAACG,kBAAkB,EAAEF,KAAK,EAAE;MACpD,IAAI,IAAI,CAACF,WAAW,CAACC,GAAG,CAACI,oBAAoB,EAA